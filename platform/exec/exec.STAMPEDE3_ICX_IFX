#! /usr/bin/env bash
#
# FUNCTION:
#  Parallel execution script
#---------------------------------------------------

simdir=${1}
nmpi=${2}
exec=${3}
nomp=${4}

# nmpi = MPI tasks
# nomp = OpenMP threads per MPI task

. $GACODE_ROOT/shared/bin/gacode_mpi_tool

cd $simdir

export OMP_NUM_THREADS=$nomp
export OMP_STACKSIZE=32M
echo ibrun $exec
ibrun $exec
