#! /usr/bin/env bash
# GACODE Parallel execution script (KFE KAIROS - Cray)

simdir=${1}
nmpi=${2}
exec=${3}
nomp=${4}

# nmpi = MPI tasks
# nomp = OpenMP threads per MPI task

. $GACODE_ROOT/shared/bin/gacode_mpi_tool

cd $simdir

export OMP_NUM_THREADS=$nomp

echo "> aprun -n $nmpi -d $nomp $exec"
aprun -n $nmpi -d $nomp $exec
