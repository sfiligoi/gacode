#!/usr/bin/env python

import os,sys,glob
import numpy as np
import argparse
import textwrap

# Command line option parser
def opts():

    mytext = '''\
    output:
       This command generates cgyro input directories based on a template.
       Examples:

       xgyrodir -i <template>     (run)
    '''

    parser = argparse.ArgumentParser(
        formatter_class=argparse.RawTextHelpFormatter,
        prog = 'xgyrodir',
        description="Directory generator",
        epilog=textwrap.dedent(mytext))

    parser.add_argument('-i',
                        help='initial directory (default: cwd)',
                        type=str,
                        default='null')
    parser.add_argument('-f',
                        help='Force overwrite',
                        action='store_true')
    parser.add_argument('-v',
                        help='Verbose output',
                        action='store_true')
    
    args=parser.parse_args()

    return args.i,args.f,args.v

#------------------------------------------------------------------------
#
infile,force,verbose = opts()

with open('pre.xgyro', 'r') as f:
    # Reject lines that start with '#' or are blank
    lines = [line for line in f if line.strip() and not line.strip().startswith('#')]

cpu = []
apar = []
base = 'a'

# Old directory check
if glob.glob(base+'*/'):
    if force:
        os.system('rm -r {}*'.format(base))
    else:
        print('ERROR: clean directories first')
        sys.exit()

# Create new directories
i = 1
for line in lines:
    row = line.strip().split()
    if row[0] == 'ALL':
        apar = row[1:]
        continue
    sdir = base+str(i)
    i = i+1
    os.system('mkdir '+sdir)
    os.system('cp input.cgyro '+sdir) 
    cpu.append(int(row[0]))
    for par in row[1:]:
        # Add parameter to local input.cgyro
        action = 'echo {} >> {}/input.cgyro'.format(par,sdir)
        os.system(action)
        if len(apar) > 0:
            for par in apar:
                action = 'echo {} >> {}/input.cgyro'.format(par,sdir)
                os.system(action)


n = len(cpu)

# header for input.xgyro 
mystr = '# This file created by xgyrodir\n# N_MPI={}\nN_DIRS={}'.format(sum(cpu),n)
action = 'echo "{}" > input.xgyro'.format(mystr)

os.system(action)

for i in range(n):
    action = 'echo "DIR_{} = {}{}" >> input.xgyro'.format(i+1,base,i+1)
    os.system(action)
