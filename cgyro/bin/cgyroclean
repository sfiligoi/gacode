#!/usr/bin/env python

import os,sys
import numpy as np
import argparse
import textwrap

# Command line option parser
def opts():

    mytext = '''\
    output:
       This command provides tools for cleaning and copying cgyro directories.
       Examples:

       cgyroclean -c              (cleans current directory)
       cgyroclean -opt            (cleans current directory leaving timing files)
       cgyroclean -i idir         (creates copy of idir without restart files)
       cgyroclean -i idir -t tdir (creates tdir without restart files of idir)
    '''

    parser = argparse.ArgumentParser(
        formatter_class=argparse.RawTextHelpFormatter,
        prog = 'cgyroclean',
        description="Directory clean/copy utility",
        epilog=textwrap.dedent(mytext))

    parser.add_argument('-i',
                        help='initial directory (default: cwd)',
                        type=str,
                        default='.')
    parser.add_argument('-t',
                        help='target directory (default: _copy)',
                        type=str,
                        default='.')
    parser.add_argument('-c',
                        help='Clean directory (all out.* and bin.* files)',
                        action='store_true')
    parser.add_argument('-v',
                        help='Verbose output',
                        action='store_true')
    parser.add_argument('-opt',
                        help='Clean directory except for timing files',
                        action='store_true')
 
    args=parser.parse_args()

    return args.i,args.t,args.c,args.v,args.opt

#------------------------------------------------------------------------
#
idir,tdir,c,v,opt = opts()

if tdir == '.':
    tdir = idir+'_copy/'

idir = idir+'/'

if v:
    flags = '-av'
else:
    flags = '-a'

if opt:
    exfiles = ['bin.cgyro.restart',
               'bin.cgyro.restart.old',
               'halt',
               'gyrotest_flag',
               'out.log',
               'out.cgyro.timing']
else:
    exfiles = ['bin.cgyro.restart',
               'bin.cgyro.restart.old',
               'halt',
               'gyrotest_flag',
               'out.log']

exstr = ""
for ex in exfiles:
    exstr = exstr+"--exclude '"+ex+"' "

os.system("rsync "+flags+" "+exstr+idir+" "+tdir)


