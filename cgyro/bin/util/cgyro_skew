#!/usr/bin/env python
import argparse
from collections import defaultdict
import numpy as np
import matplotlib.pyplot as plt
from matplotlib import rc, ticker
rc('text', usetex=True)
rc('font', family='serif', size=16)
from pygacode.gacodefuncs import TEXPHI
from pygacode.cgyro import data

p = argparse.ArgumentParser(prog='cgyro_skew',
   description='Plot extended ballooning mode structure')
p.add_argument('-e', metavar='DIR', type=str, default='./',
               help='Simulation directory (default: ./)')
p.add_argument('-itime', metavar='N', type=int, default=-1,
               help='Time index (default: -1 = last)')
p.add_argument('-n', metavar='N', type=int, default=1,
               help='Toroidal mode number')
p.add_argument('-s', metavar='S', type=int, default=0,
               help='Ballooning mode index (default: 0)')
p.add_argument('-lx', metavar='L', type=float, default=14,
               help='Figure width (default: 14)')
p.add_argument('-ly', metavar='L', type=float, default=6,
               help='Figure height (default: 6)')
p.add_argument('-dot', action='store_true',
               help='Show data points as circles')
p.add_argument('-save', metavar='FILE', type=str, default=None,
               help='Save to file (format from extension: .pdf, .png)')
p.add_argument('-remote', metavar='DIR', type=str, default=None,
               help='Data directory (overrides -e); output written to current directory')
p.add_argument('-global', dest='use_global', action='store_true',
               help='Normalize by global fmax across all sectors (for cross-sector comparison)')
a = p.parse_args()

# Ensure trailing slash
if not a.e.endswith('/'):
   a.e += '/'

if a.remote:
   a.e = a.remote

# Load data
sim = data.cgyrodata(a.e)
sim.getbigfield()
t = sim.getnorm('elec')
a.itime = min(a.itime, sim.n_time-1)

if sim.n_n == 1:
   f = sim.kxky_phi[:,:,0,a.itime]
   a.n = 1
else:
   f = sim.kxky_phi[:,:,a.n,a.itime]

ylabel = r'$\phi/\phi_\mathrm{norm}$'
ybox = r'$\phi_\mathrm{norm}'

f /= sim.rhonorm

m = sim.n_radial//2
l = sim.m_box*a.n

phi = 2*np.pi*sim.q/sim.m_box
theta0 = 2.0*a.s/l

print('INFO: (cgyro_skew) n={}, l={}, s={}'.format(a.n,l,a.s))
print('INFO: (cgyro_skew) (c_s/a) t = {:.2f}'.format(t[a.itime]))

# Sort extended p indices into ballooning angle bins
pvec = defaultdict(list)
for p in range(-l-m, m+l):
   pvec[p % l].append(p)

# Build ballooning mode curve for selected mode s
#
# Key formula: f(p,z) = F(z+2*pi*p/l) * exp(i*phi*p)
tstar = [(sim.thetap+2*np.pi/l*p)/np.pi - theta0 for p in pvec[a.s]]
fstar = [f[(p+m)%(2*m),:]*np.exp(-1j*p*phi) for p in pvec[a.s]]
tvec = np.concatenate(tstar)
fvec = np.concatenate(fstar)

# Normalize: per-sector (default) or global across all sectors (-global flag)
if a.use_global:
   fmax = max(np.max(np.abs(f[(p+m)%(2*m),:]*np.exp(-1j*p*phi)))
              for s in range(l) for p in pvec[s])
else:
   fmax = np.max(np.abs(fvec))
fvec /= fmax

# Plot
fig, ax = plt.subplots(figsize=(a.lx, a.ly))
ax.grid(which='major', ls=':')
ax.set_xlabel(r'$(\theta_*-\theta_0)/\pi$')
ax.set_ylabel(ylabel)
# Determine label placement: outside plot area to avoid data overlap
# Title goes inside plot on the opposite side
idx = np.argmax(np.abs(fvec))
if np.real(fvec[idx]) > 0:
   label_y, label_va = 0.02, 'bottom'
   title_y, title_va = 0.97, 'top'
else:
   label_y, label_va = 0.98, 'top'
   title_y, title_va = 0.03, 'bottom'

title_str = r'$n={},\; \ell={},\; s={}$  ($s=0$--${})$'.format(a.n,l,a.s,l-1)
ax.text(0.02, title_y, title_str, ha='left', va=title_va,
        transform=ax.transAxes, fontsize=16,
        bbox=dict(facecolor='white', edgecolor='black', linewidth=0.5, pad=4, alpha=0.8))

exp = int(np.floor(np.log10(fmax)))
mantissa = fmax / 10**exp
norm_str = ybox+r'= {:.2f}\times10^{{{}}}$'.format(mantissa, exp)
ax.text(0.98, title_y, norm_str, ha='right', va=title_va,
        transform=ax.transAxes, fontsize=14,
        bbox=dict(facecolor='white', edgecolor='black', linewidth=0.5, pad=4, alpha=0.8))

n_strips = len(pvec[a.s])
label_rotation = 90 if n_strips > 10 else 0

# Shade strips and mark boundaries
boundaries = set()
for p in pvec[a.s]:
   sl = -1.0 + 2.0*p/l - theta0
   sr =  1.0 + 2.0*p/l - theta0
   extended = (p < -m or p >= m)
   c = 'lightcoral' if extended else 'lightblue'
   ax.axvspan(sl, sr, color=c, alpha=0.2)
   if extended:
      p_mod = (p + m) % (2*m) - m
      s_eff = p_mod % l
      label = r'$p={}$'.format(p_mod)
      label += '\n' + r'$s^\prime={}$'.format(s_eff)
   else:
      label = r'$p={}$'.format(p)
   ax.text((sl+sr)/2, label_y, label, ha='center', va=label_va,
           rotation=label_rotation,
           transform=ax.get_xaxis_transform(), fontsize=12, color='black',
           bbox=dict(facecolor='whitesmoke', edgecolor='black', linewidth=0.5, pad=3))
   boundaries |= {sl, sr}

for b in boundaries:
   ax.axvline(b, color='grey', linewidth=0.5)
ax.set_xticks(sorted(boundaries))

# Data curves
ax.plot(tvec, np.real(fvec), '-o' if a.dot else '-', color='black', markersize=1.5)
ax.plot(tvec, np.imag(fvec), '--', color='black')

# Set axis limits to data limits
xpad = 0.01*(tvec.max() - tvec.min())
ax.set_xlim(tvec.min() - xpad, tvec.max() + xpad)
ymin = np.min([np.real(fvec), np.imag(fvec)])
ymax = np.max([np.real(fvec), np.imag(fvec)])
ypad = 0.1*(ymax - ymin)
ax.set_ylim(ymin - ypad, ymax + ypad)
ax.yaxis.set_major_formatter(ticker.FormatStrFormatter('%.1f'))

fig.tight_layout(pad=0.3)
if a.save:
   fig.savefig(a.save)
   print('INFO: (cgyro_skew) Saved to {}'.format(a.save))
else:
   plt.show()
