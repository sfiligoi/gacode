#!/usr/bin/env python

# Standard library
import os
import re
import sys
import warnings
import argparse
import textwrap
import json

# Third-party
import numpy as np
import matplotlib.pyplot as plt
from matplotlib import rc
from pydmd import DMD

# Local
from cgyro.data import cgyrodata

# Maximum number of DMD modes to test
NMODE_MAX = 16

# Output file names
OUTFILE_DMD = 'out.cgyro.dmd'
OUTFILE_JSON = 'json.cgyro.dmd'

# Observable definitions: attribute name, slice indices, label
OBSERVABLE_DEFS = {
    'phi':  ('kxky_phi',  lambda d, imax: d[:, :, 0, :imax],        r'$\delta \widetilde{\phi}$'),
    'apar': ('kxky_apar', lambda d, imax: d[:, :, 0, :imax],        r'$\delta \hskip -1pt \widetilde{A}_\parallel$'),
    'bpar': ('kxky_bpar', lambda d, imax: d[:, :, 0, :imax],        r'$\delta \hskip -1pt \widetilde{B}_\parallel$'),
    'ni':   ('kxky_n',    lambda d, imax: d[:, :, 0, 0, :imax],     r'$\delta n_i$'),
    'ne':   ('kxky_n',    lambda d, imax: d[:, :, -1, 0, :imax],    r'$\delta \widetilde{n}_e$'),
    'vi':   ('kxky_v',    lambda d, imax: d[:, :, 0, 0, :imax],     r'$\delta v_i$'),
    've':   ('kxky_v',    lambda d, imax: d[:, :, -1, 0, :imax],    r'$\delta \widetilde{v}_e$'),
    'ei':   ('kxky_e',    lambda d, imax: d[:, :, 0, 0, :imax],     r'$\delta E_i$'),
    'ee':   ('kxky_e',    lambda d, imax: d[:, :, -1, 0, :imax],    r'$\delta \widetilde{E}_e$'),
}


def parse_args():
    """Command line option parser."""
    epilog = '''\
    output:
       This tool will analyze a linear CGYRO run based on the time history
       of selected fields. Subdominant and even stable modes can be computed.
    '''

    parser = argparse.ArgumentParser(
        formatter_class=argparse.RawTextHelpFormatter,
        prog='cgyro_dmd',
        description="CGYRO DMD utility",
        epilog=textwrap.dedent(epilog))

    parser.add_argument('-e',
                        help="working directory (default: cwd)",
                        type=str,
                        default='.')
    parser.add_argument('-tmax',
                        help='Fraction of time samples to retain (default=1.0)',
                        type=float,
                        default=1.0)
    parser.add_argument('-k',
                        help='Time sample spacing (default=1)',
                        type=int,
                        default=1)
    parser.add_argument('-obs',
                        help="Comma-separated list of 3 observables",
                        type=str,
                        default='phi,apar,bpar')
    parser.add_argument('-tol',
                        help='Root acceptance tolerance (default=0.005)',
                        type=float,
                        default=0.005)
    parser.add_argument('-eps',
                        help='Averaging sharpness',
                        type=float,
                        default=0.01)
    parser.add_argument('-ext',
                        help='Plotting file format [png,pdf] (default: screen)',
                        type=str,
                        default='screen')
    parser.add_argument('-noplot',
                        help='Switch off plotting',
                        action='store_true')
    parser.add_argument('-noeig',
                        help='Switch off eigenmode plotting',
                        action='store_true')
    parser.add_argument('-tag',
                        help='Tag eigenmodes (-tag ITG,null,TEM,null,KBM)',
                        type=str,
                        default='')

    return parser.parse_args()


def downsample(f, n, eps=0.01):
    """Downsample with weighted averaging (eps controls flatness)."""
    npar = f.shape[0]
    nave = f.shape[1]

    # Trim array to multiple of n
    m = (nave // n) * n

    # Weighted downsample
    u = np.linspace(-1, 1, n)
    w = 1 / (1 + eps * u * u)
    w = w / np.sum(w)

    fdown = np.sum(f[:, :m].reshape(npar, -1, n) * w[None, None, :], axis=2)

    return fdown


def map_to_ballooning(f2d, q):
    """Map from (kx, theta) to extended ballooning angle theta_*."""
    n_radial = f2d.shape[0]
    n_theta = f2d.shape[1]
    ntime = f2d.shape[2]

    px = np.arange(n_radial) - n_radial // 2
    f1d = np.zeros([n_radial, n_theta, ntime], dtype=complex)
    anorm = f1d[n_radial // 2, n_theta // 2, :]

    for ir in range(n_radial):
        f1d[ir, :, :] = f2d[ir, :, :] * np.exp(-2 * np.pi * 1j * px[ir] * q)
    f1d = f1d.reshape(n_radial * n_theta, ntime)

    return f1d, anorm


def run_dmd(dmd, obs_names, obs_data, t, k, eps, tol, n_radial, n_theta):
    """
    Run DMD analysis on observables.

    Returns:
        n_modes: number of matched modes found
        mode_indices: list of [obs1_idx, obs2_idx, obs3_idx] for each mode
        dt: time step used
        eigenfreqs: complex eigenfrequencies
        eigenmodes: eigenmodes for each observable
        errors: fitting errors
        eig_dict: raw eigenvalues by observable
        eig_sorted: sorted eigenvalues array
    """
    nmode = NMODE_MAX
    dt = k * (t[1] - t[0])

    # Dictionaries for eigenvalues and eigenmodes by observable
    eig_dict = {}
    mode_dict = {}
    cond_number = None

    for obs in obs_names:
        down = downsample(obs_data[obs], k, eps=eps)
        with warnings.catch_warnings(record=True) as w:
            warnings.simplefilter('always')
            dmd.fit(down)
            for warning in w:
                if 'condition number' in str(warning.message):
                    match = re.search(r'condition number ([\d.e+]+)', str(warning.message))
                    if match and cond_number is None:
                        cond_number = float(match.group(1).rstrip('.'))
        eig_dict[obs] = 1j * np.log(dmd.eigs) / dt
        mode_dict[obs] = dmd.modes
        if len(dmd.eigs) < nmode:
            nmode = len(dmd.eigs)

    if cond_number is not None:
        print(f'INFO: (cgyro_dmd) log10(condition number) = {np.log10(cond_number):.1f}')

    # Sort eigenvalues by growth rate (imaginary part)
    eig_sorted = np.zeros([3, nmode], dtype=complex)
    mode_sorted = np.zeros([3, n_radial * n_theta, nmode], dtype=complex)

    for i, obs in enumerate(obs_names):
        z = eig_dict[obs]
        sort_idx = np.flip(np.argsort(z.imag))
        eig_sorted[i, :] = z[sort_idx[:nmode]]
        mode_sorted[i, :, :] = mode_dict[obs][:, sort_idx[:nmode]]

    # Find matching eigenvalues across observables
    # matches_01: pairs where obs1 eigenvalue matches obs2
    # matches_02: pairs where obs1 eigenvalue matches obs3
    matches_01 = []
    matches_02 = []

    for i in range(nmode):
        for j in range(nmode):
            if abs(eig_sorted[0, i] - eig_sorted[1, j]) < tol:
                matches_01.append([i, j])
            if abs(eig_sorted[0, i] - eig_sorted[2, j]) < tol:
                matches_02.append([i, j])

    # Find 3-way matches (legitimate modes)
    mode_indices = []
    for v in matches_01:
        for w in matches_02:
            if v[0] == w[0]:
                mode_indices.append([v[0], v[1], w[1]])

    n_modes = len(mode_indices)
    if n_modes < 1:
        print('ERROR: (cgyro_dmd) No modes found. Try increasing run length.')
        return 0, [], dt, [], [], [1], [], []

    # Compute eigenfrequencies and errors for matched modes
    errors = np.zeros(n_modes)
    eigenfreqs = np.zeros(n_modes, dtype=complex)
    eigenmodes = np.zeros([3, n_radial * n_theta, n_modes], dtype=complex)

    for m in range(n_modes):
        j = np.array(mode_indices[m])
        eigenfreqs[m] = np.trace(eig_sorted[:, j[:]]) / 3
        errors[m] = np.trace(abs(eig_sorted[:, j[:]] - eigenfreqs[m]))
        for i in range(3):
            eigenmodes[i, :, m] = mode_sorted[i, :, j[i]]

    return n_modes, mode_indices, dt, eigenfreqs, eigenmodes, errors, eig_dict, eig_sorted


def collect_observables(sim, imax):
    """Collect available observables from simulation data."""
    obs_data = {}

    for name, (attr, slicer, _) in OBSERVABLE_DEFS.items():
        try:
            data = getattr(sim, attr)
            y = slicer(data, imax)
            obs_data[name], _ = map_to_ballooning(y, sim.q)
        except:
            pass

    return obs_data


def get_obs_label(name):
    """Get LaTeX label for observable."""
    return OBSERVABLE_DEFS.get(name, (None, None, name))[2]


def setup_eigenmode_axis(ax, xt, ylabel):
    """Configure axis for eigenmode plotting."""
    x0 = max(xt)
    y0 = 1.02

    ax.set_xlabel(r"$\theta_p/\pi$")
    ax.text(-0.88 * x0, 0.65 * y0, r'\fbox{' + ylabel + '}')

    ax.plot([-x0, x0], [0, 0], linestyle=':', alpha=0.2, color='k')
    ax.plot([0, 0], [-y0, y0], linestyle=':', alpha=0.2, color='k')
    ax.set_xlim(-x0, x0)
    ax.set_ylim(-y0, y0)

    return ax


def plot_eigenvalues(obs_names, eig_dict, eig_sorted, mode_indices, eigenfreqs,
                     plot_styles, mydir, ext):
    """Plot eigenvalue spectrum."""
    mlabel = [chr(65 + m) for m in range(26)]
    marker_size = 200
    yeps = 0.004

    rc('font', size=28)
    rc('text', usetex=True)

    fig = plt.figure(figsize=(9, 7.5))
    ax = fig.add_subplot(111)

    ax.set_xlabel(r"$(a/c_s)\,\omega$")
    ax.set_ylabel(r"$(a/c_s)\,\gamma$")
    ax.grid(which="both", ls=":")
    ax.grid(which="major", ls=":")

    # Plot all modes (faded)
    for obs in obs_names:
        ax.scatter(eig_dict[obs].real, eig_dict[obs].imag,
                   s=marker_size, **plot_styles[obs], alpha=0.4)

    # Plot legitimate modes with labels
    n_modes = len(mode_indices)
    haslabel = False
    for m in range(n_modes):
        j = np.array(mode_indices[m])
        for i, obs in enumerate(obs_names):
            x0 = eig_sorted[i, j[i]].real
            y0 = eig_sorted[i, j[i]].imag
            if haslabel:
                ax.scatter(x0, y0, s=marker_size, **plot_styles[obs])
            else:
                ax.scatter(x0, y0, s=marker_size, **plot_styles[obs],
                           label=get_obs_label(obs))
        haslabel = True
        ax.text(x0, y0 + yeps, mlabel[m],
                verticalalignment='bottom', horizontalalignment='center')

    xmax = max(np.real(eigenfreqs)) + 0.09
    xmin = min(np.real(eigenfreqs)) - 0.09
    ymax = max(np.imag(eigenfreqs)) + 0.07
    ymin = min(np.imag(eigenfreqs)) - 0.1
    ax.set_xlim([xmin, xmax])
    ax.set_ylim([ymin, ymax])
    ax.axvline(0, color='k', linestyle=':')
    ax.axhline(0, color='k', linestyle=':')
    ax.legend(loc=4)

    plt.tight_layout(pad=0.3)
    if ext == 'screen':
        plt.show()
    else:
        plt.savefig(mydir + 'out.cgyro.dmd_freq.' + ext)


def plot_eigenmodes(obs_names, obs_data, eigenmodes, n_modes, n_radial, n_theta,
                    mydir, ext):
    """Plot eigenmode structure."""
    dtheta = 2 * np.pi / n_theta
    thetab = np.arange(n_theta * n_radial) * dtheta - (n_radial + 1) * np.pi
    xt = thetab / np.pi

    rc('font', size=18)

    ly = 1 + 2 * n_modes if n_modes < 4 else 9
    fig = plt.figure(figsize=(9, ly))

    for m in range(n_modes):
        for i, obs in enumerate(obs_names):
            ax = fig.add_subplot(n_modes, 3, i + 1 + 3 * m)
            ax = setup_eigenmode_axis(ax, xt, get_obs_label(obs))

            # # Plot initial-value (disabled)
            # if m == -1:
            #     p = np.argmax(abs(obs_data[obs][:, -1]))
            #     a00 = obs_data[obs][p, -1]
            #     yr = np.real(obs_data[obs][:, -1] / a00)
            #     yi = np.imag(obs_data[obs][:, -1] / a00)
            #     ax.plot(xt, yr, color='k', linewidth=2, alpha=0.3, linestyle='--')
            #     ax.plot(xt, yi, color='r', linewidth=2, alpha=0.3, linestyle='--')

            # Plot DMD eigenmode
            p = np.argmax(abs(eigenmodes[i, :, m]))
            a0d = eigenmodes[i, p, m]
            yr = np.real(eigenmodes[i, :, m] / a0d)
            yi = np.imag(eigenmodes[i, :, m] / a0d)
            ax.plot(xt, yr, color='k', linewidth=1)
            ax.plot(xt, yi, color='r', linewidth=1)

            if m + 1 < n_modes:
                ax.set_yticks([])
                ax.set_xticks([])
                ax.set_xlabel('')
                ax.set_ylabel('')
            else:
                ax.set_yticks([])
                ax.set_ylabel('')
                ax.grid(False)

    plt.tight_layout(pad=0.05)
    if ext == 'screen':
        plt.show()
    else:
        plt.savefig(mydir + 'out.cgyro.dmd_mode.' + ext)


def main():
    args = parse_args()

    mydir = args.e + '/'
    obs_names = args.obs.split(',')

    # Plot styling for each observable
    plot_styles = {
        obs_names[0]: {'color': 'r', 'marker': 'o', 'facecolors': 'none'},
        obs_names[1]: {'color': 'b', 'marker': 's', 'facecolors': 'none'},
        obs_names[2]: {'color': 'k', 'marker': '+'},
    }

    # Load simulation data
    sim = cgyrodata(mydir, silent=True)
    sim.getbigfield()

    if sim.hiprec_flag == 0:
        print('ERROR: (cgyro_dmd) Need to run cgyro with HIPREC_FLAG=1')
        sys.exit(1)

    t = sim.t
    n_radial = sim.n_radial
    n_theta = sim.theta_plot
    imax = int(len(t) * args.tmax)

    # Collect observables
    obs_data = collect_observables(sim, imax)
    available = list(obs_data.keys())

    print('---------------------- CGYRO-DMD ------------------------------')
    print('observables selected: ' + args.obs)
    print('observables available:', available)
    print()

    if len(available) < 3:
        print('NOT ENOUGH DATA')
        sys.exit(1)

    # Initialize DMD and run analysis
    dmd = DMD(svd_rank=0, exact=True, sorted_eigs='abs')

    n_modes, mode_indices, dt, eigenfreqs, eigenmodes, errors, eig_dict, eig_sorted = \
        run_dmd(dmd, obs_names, obs_data, t, args.k, args.eps, args.tol, n_radial, n_theta)

    if n_modes < 1:
        sys.exit(1)

    # Write standard output file
    with open(mydir + OUTFILE_DMD, 'w') as f:
        f.write('# cgyro_dmd\n')
        f.write(f'# k = {args.k}\n')
        f.write(f'# tmax = {t[imax-1]:.1f} a/cs | w*tmax = {abs(eigenfreqs[0])*t[imax-1]:.2f}\n')
        f.write(f'# dt   = {dt:.3f} a/cs | w*dt   = {abs(eigenfreqs[0])*dt:.3f}\n')
        f.write('# gamma     omega     error\n')
        for m in range(n_modes):
            f.write(f'{eigenfreqs[m].imag:+.5f}  {eigenfreqs[m].real:+.5f}  {errors[m]:.4e} \n')

    print()
    os.system('cat ' + mydir + OUTFILE_DMD)

    # Write tagged JSON output
    if args.tag:
        data = {'KY': sim.ky[0]}
        for m, name in enumerate(args.tag.split(',')):
            data[name] = [eigenfreqs[m].imag, eigenfreqs[m].real]
        with open(mydir + OUTFILE_JSON, 'w') as f:
            json.dump(data, f, indent=2)

    if args.noplot:
        sys.exit()

    # Plot eigenvalue spectrum
    plot_eigenvalues(obs_names, eig_dict, eig_sorted, mode_indices, eigenfreqs,
                     plot_styles, mydir, args.ext)

    if args.noeig:
        sys.exit()

    # Plot eigenmodes
    plot_eigenmodes(obs_names, obs_data, eigenmodes, n_modes, n_radial, n_theta,
                    mydir, args.ext)


if __name__ == '__main__':
    main()
