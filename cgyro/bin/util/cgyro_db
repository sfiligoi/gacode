def parse_filters(filter_args):
    """
    Parse filter arguments from command line

    Examples:
    ---------
    'q=1.5:2.0' -> {'q': (1.5, 2.0)}
    'shear=0.8' -> {'shear': 0.8}
    'case_path=%scan%' -> {'case_path': '%scan%'}
    """
    if not filter_args:
        return None

    filters = {}
    for arg in filter_args:
        if '=' not in arg:
            print(f"Warning: Invalid filter format '{arg}', skipping")
            continue

        key, value = arg.split('=', 1)

        # Check if range query (contains :)
        if ':' in value:
            try:
                vmin, vmax = value.split(':')
                filters[key] = (float(vmin), float(vmax))
            except ValueError:
                print(f"Warning: Invalid range format '{value}', skipping")
        else:
            # Try to convert to float, else keep as string
            try:
                filters[key] = float(value)
            except ValueError:
                filters[key] = value

    return filters if filters else None


def get_default_db_path(db_name='cgyro.db'):
    """Get database path, using ~/.cgyro/ for plain filenames."""
    if os.path.sep in db_name or db_name.startswith('~'):
        return os.path.expanduser(db_name)
    return get_user_config_path(db_name)


def refresh_directories(root_dir='./', linear=False):
    """
    Refresh directories by re-running cgyro_parse.py and cgyro

    Parameters:
    -----------
    root_dir : str
        Root directory to search for CGYRO cases
    linear : bool
        If True, include linear simulations in refresh
    """
    import subprocess

    cases = find_cgyro_cases(root_dir, linear=linear)
    print(f"Found {len(cases)} CGYRO cases to refresh")

    gacode_root = os.environ.get('GACODE_ROOT')
    if not gacode_root:
        print("ERROR: GACODE_ROOT environment variable not set")
        sys.exit(1)

    for case_dir in tqdm(cases, desc="Refreshing cases"):
        tqdm.write(f"Refreshing {case_dir}")
        try:
            # Run cgyro_parse.py
            subprocess.run(
                f"cd {case_dir} && python {gacode_root}/cgyro/bin/cgyro_parse.py",
                shell=True,
                check=True
            )
            # Run cgyro executable
            subprocess.run(
                f"cd {case_dir} && {gacode_root}/cgyro/src/cgyro",
                shell=True,
                check=True
            )
        except subprocess.CalledProcessError as e:
            print(f"ERROR refreshing {case_dir}: {e}")
            continue


def legacy_refresh_directories(root_dir='./', linear=False):
    """
    Legacy profile refresh: convert old input format

    Parameters:
    -----------
    root_dir : str
        Root directory to search for CGYRO cases
    linear : bool
        If True, include linear simulations in refresh
    """
    import subprocess

    cases = find_cgyro_cases(root_dir, linear=linear)
    print(f"Found {len(cases)} CGYRO cases for legacy refresh")

    gacode_root = os.environ.get('GACODE_ROOT')
    if not gacode_root:
        print("ERROR: GACODE_ROOT environment variable not set")
        sys.exit(1)

    for case_dir in tqdm(cases, desc="Legacy refreshing cases"):
        tqdm.write(f"Legacy refreshing {case_dir}")
        try:
            # Process input.cgyro.gen with cgyro --json
            subprocess.run(
                f"cgyro --json -e {case_dir}",
                shell=True,
                check=True
            )
            # Copy output to input
            subprocess.run(
                f"cd {case_dir} && cp out.cgyro.localdump input.cgyro",
                shell=True,
                check=True
            )
            # Run cgyro_parse.py
            subprocess.run(
                f"cd {case_dir} && python {gacode_root}/cgyro/bin/cgyro_parse.py",
                shell=True,
                check=True
            )
            # Run cgyro executable
            subprocess.run(
                f"cd {case_dir} && {gacode_root}/cgyro/src/cgyro",
                shell=True,
                check=True
            )
        except subprocess.CalledProcessError as e:
            print(f"ERROR legacy refreshing {case_dir}: {e}")
            continue


def main():
    """Main entry point for cgyro_db CLI"""
    mytext = '''\
    examples:
       cgyro_db -info                        Show implemented fields
       cgyro_db -init                        Initialize/reset database
       cgyro_db -scan -flux                  Scan and include flux data

       cgyro_db -i nersc.db -scan            Use custom database name
       cgyro_db -i /path/to/my.db -q ""      Use database at full path

       cgyro_db -show-case /path/to/case     Show complete record for a case
       cgyro_db -show-hash 12345678          Show complete record by 8-digit hash
       cgyro_db -i nersc.db -show-hash abc   Show case from custom database

       cgyro_db -ref                         Refresh nonlinear CGYRO cases (re-run parse and cgyro)
       cgyro_db -ref -linear                 Refresh all cases including linear
       cgyro_db -lref                        Legacy refresh (convert old input format)
       cgyro_db -lref -linear                Legacy refresh including linear cases

       cgyro_db -q ""                        List all cases (minimal: #, path, hash)
       cgyro_db -q "" -fields standard       Add physics parameters (q, shear, kappa, etc.)
       cgyro_db -q "q=1.5:2.0"               Filter cases by q range

       cgyro_db -q "" -show-flux energy      Show energy flux for all species
       cgyro_db -q "" -show-flux s0_energy s0_particle   Show electron energy and particle flux
       cgyro_db -q "" -show-flux energy particle         Show all energy and particle fluxes

       cgyro_db -q "q=1.5:2.0" -export csv -o results.csv
       cgyro_db -stats                       Show database statistics

    default database: ~/.cgyro/cgyro.db
    flux column naming: s0_e (species 0 energy), s1_p (species 1 particle), s0_m (species 0 momentum)
    '''

    parser = argparse.ArgumentParser(
        formatter_class=argparse.RawTextHelpFormatter,
        prog='cgyro_db',
        description='CGYRO Database Manager - Create lightweight databases for AI training',
        epilog=textwrap.dedent(mytext))

    parser.add_argument('-init', '--initialize',
                        help='Initialize/reset the database (requires confirmation)',
                        action='store_true')

    parser.add_argument('-scan', '--scan',
                        help='Scan and update AI database',
                        action='store_true')

    parser.add_argument('-q', '--query',
                        help='Query database with filters (e.g., q=1.5:2.0 shear=0.8)',
                        nargs='*')

    parser.add_argument('-fields',
                        help='Fields to show: minimal (default), standard, all',
                        type=str,
                        choices=['minimal', 'standard', 'all'],
                        default='minimal')

    parser.add_argument('-show-flux',
                        help='Add flux columns: energy, particle, momentum, or species-specific (e.g., s0_energy)',
                        nargs='*')

    parser.add_argument('-export', '--export',
                        help='Export results (csv or json)',
                        type=str,
                        choices=['csv', 'json'])

    parser.add_argument('-o', '--output',
                        help='Output file path',
                        type=str)

    parser.add_argument('-stats', '--statistics',
                        help='Show database statistics',
                        action='store_true')

    parser.add_argument('-info', '--information',
                        help='Show implemented fields and database schema',
                        action='store_true')

    parser.add_argument('-flux',
                        help='Include flux data in scan',
                        action='store_true')

    parser.add_argument('-ref', '--refresh',
                        help='Refresh directories (re-run cgyro_parse.py and cgyro)',
                        action='store_true')

    parser.add_argument('-lref', '--legacy-refresh',
                        help='Legacy profile refresh (convert old input format)',
                        action='store_true')

    parser.add_argument('-linear',
                        help='Include linear simulations (use with -ref or -lref)',
                        action='store_true')

    parser.add_argument('-i', '--input',
                        help='Database name (placed in ~/.cgyro/) or full path',
                        type=str,
                        default='cgyro.db')

    parser.add_argument('-show-case',
                        help='Show complete record for a case by path',
                        type=str,
                        metavar='PATH')

    parser.add_argument('-show-hash',
                        help='Show complete record for a case by 8-digit input hash',
                        type=str,
                        metavar='HASH')

    args = parser.parse_args()

    # Get database path
    db_path = get_default_db_path(args.input)

    # Command execution
    if args.show_case:
        if not os.path.exists(db_path):
            print(f"ERROR: Database not found at: {db_path}")
            sys.exit(1)

        db = AIDB(db_path)
        case = db.get_case_by_path(args.show_case)
        if case is None:
            print(f"ERROR: Case not found: {args.show_case}")
            db.close()
            sys.exit(1)

        complete_case = db.get_complete_case(case['case_id'])
        display_complete_case(complete_case)
        db.close()

    elif args.show_hash:
        if not os.path.exists(db_path):
            print(f"ERROR: Database not found at: {db_path}")
            sys.exit(1)

        db = AIDB(db_path)
        case = db.get_case_by_hash(args.show_hash)
        if case is None:
            print(f"ERROR: Case not found with hash: {args.show_hash}")
            db.close()
            sys.exit(1)

        complete_case = db.get_complete_case(case['case_id'])
        display_complete_case(complete_case)
        db.close()

    elif args.refresh:
        refresh_directories(linear=args.linear)
        sys.exit(0)

    elif args.legacy_refresh:
        legacy_refresh_directories(linear=args.linear)
        sys.exit(0)

    elif args.initialize:
        # Check if database exists and ask for confirmation
        if os.path.exists(db_path):
            print(f"\nWARNING: Database already exists at: {db_path}")
            print("This will DELETE all existing data and create a fresh database.")
            response = input("Are you sure you want to continue? (yes/no): ").strip().lower()

            if response not in ['yes', 'y']:
                print("Initialization cancelled.")
                sys.exit(0)

            # Remove existing database
            os.remove(db_path)
            print(f"Removed existing database.")

        # Create new database
        db = AIDB(db_path)
        db.create_schema()
        print(f"Initialized AI database: {db_path}")
        db.close()

    elif args.scan:
        # Auto-initialize if database doesn't exist
        if not os.path.exists(db_path):
            print(f"Database not found. Creating new database at: {db_path}")
            db = AIDB(db_path)
            db.create_schema()
            db.close()

        db = AIDB(db_path)
        scan_and_update(db, './', include_flux=args.flux)
        db.close()

    elif args.query is not None:
        if not os.path.exists(db_path):
            print(f"ERROR: Database not found at: {db_path}")
            print(f"Run 'cgyro_db -scan' to create and populate the database.")
            sys.exit(1)

        db = AIDB(db_path)
        filters = parse_filters(args.query)

        # Check if flux display is requested
        if args.show_flux:
            # First check if flux data exists in database
            cursor = db.conn.execute("SELECT COUNT(*) FROM fluxes")
            flux_count = cursor.fetchone()[0]

            if flux_count == 0:
                print("\nWARNING: No flux data found in database.")
                print("Run 'cgyro_db -scan -flux' to populate flux data.")
                print("Showing query results without flux data:\n")
                df = db.query(filters=filters, show_fields=args.fields)
            else:
                # Parse flux request
                flux_types = []
                species_list = []

                for flux_spec in args.show_flux:
                    if flux_spec in ['energy', 'particle', 'momentum']:
                        flux_types.append(flux_spec)
                    elif flux_spec.startswith('s') and '_' in flux_spec:
                        # Format: s0_energy, s1_particle, etc.
                        parts = flux_spec.split('_')
                        sp = int(parts[0][1:])  # Extract species number
                        ftype = parts[1]
                        if sp not in species_list:
                            species_list.append(sp)
                        if ftype not in flux_types:
                            flux_types.append(ftype)

                # Use query_with_flux
                df = db.query_with_flux(
                    filters=filters,
                    flux_type=flux_types if flux_types else None,
                    species=species_list if species_list else None
                )
        else:
            # Regular query
            df = db.query(filters=filters, show_fields=args.fields)

        if filters:
            print(f"Querying database with filters: {filters}")

        print(f"\nFound {len(df)} cases:")
        # Display with better formatting
        import pandas as pd
        pd.set_option('display.max_columns', None)
        pd.set_option('display.width', 200)
        print(df.to_string(index=False))

        if args.export and args.output:
            if args.export == 'csv':
                db.export_csv(df, args.output)
            elif args.export == 'json':
                db.export_json(df, args.output)

        db.close()

    elif args.statistics:
        if not os.path.exists(db_path):
            print(f"ERROR: Database not found at: {db_path}")
            print(f"Run 'cgyro_db -scan' to create and populate the database.")
            sys.exit(1)

        db = AIDB(db_path)
        db.print_statistics()
        db.close()

    elif args.information:
        show_info(db_path=db_path)

    else:
        print(f"Database location: {db_path}")
        if os.path.exists(db_path):
            print(f"Database exists (size: {os.path.getsize(db_path) / 1024:.1f} KB)")
        else:
            print("Database not yet created.")
        print()
        parser.print_help()


if __name__ == '__main__':
    main()
