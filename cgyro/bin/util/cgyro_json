#!/usr/bin/env python

import os
import sys
import json
import numpy as np
import argparse
import textwrap
from pygacode.cgyro import data

garoot = os.environ['GACODE_ROOT']

#==================================================================
# Helper functions

def error_exit(msg):
    """Print error message and exit."""
    print(f'cgyro_json: (ERROR) {msg}')
    sys.exit(1)

def msg(text, indent=False):
    """Print diagnostic message if not in quiet mode."""
    if not args.quiet:
        prefix = '   ' if indent else 'cgyro_json: '
        print(f'{prefix}{text}')

def digit(f, n):
    """Round f to n decimal places."""
    if n == 0:
        return round(f)
    return round(10**n * f) / 10**n

def write_section(f, title, keys, d, first=False):
    """Write a section of key=value pairs to file, popping keys from d."""
    prefix = '' if first else '\n'
    f.write(f'{prefix}# {title}\n')
    for key in keys:
        if key in d:
            f.write(f'{key}={d.pop(key)}\n')

def tglf_species_array(tglf, prefix, arr):
    """Add TGLF species array with electron first (index 1), ions following."""
    tglf[f'{prefix}_1'] = arr[-1]  # Electron (last in CGYRO) -> first in TGLF
    for i in range(2, len(arr) + 1):
        tglf[f'{prefix}_{i}'] = arr[i-2]

def opts():

    mytext = '''\
Output files (written to working directory):
  json.cgyro.localdump  Complete parameter dump in JSON format
  json.cgyro.imas       IMAS-compatible data dictionary in JSON format
  out.cgyro.localdump   Sparse localdump (non-default values only)
  out.cgyro.tglf        Equivalent TGLF input file

Examples:
  cgyro -json                        Process simulation in current directory
  cgyro -json -e /path/to/sim        Process simulation in specified directory
  cgyro -json -template in.cgyro     Generate input.cgyro with resolution defaults
  cgyro -json -template in.cgyro -nx 128 -ne 12   Override specific resolution
    '''

    parser = argparse.ArgumentParser(
        formatter_class=argparse.RawTextHelpFormatter,
        prog = 'cgyro_json',
        description="Export CGYRO simulation data to JSON and other formats.\n"
                    "Requires input.cgyro.gen (run 'cgyro -t' first if needed).\n\n"
                    "With -template: Generate input.cgyro from physics template,\n"
                    "adding resolution parameters (from defaults or command line).",
        epilog=textwrap.dedent(mytext))

    parser.add_argument('-e',
                        metavar='DIR',
                        help="Working directory containing CGYRO data (default: cwd)",
                        type=str,
                        default='.')

    parser.add_argument('-template',
                        metavar='FILE',
                        help="Process an input.cgyro physics template and generate\n"
                             "a complete input.cgyro with resolution parameters",
                        type=str,
                        default='null')

    # Spatial resolution
    parser.add_argument('-nx',
                        metavar='N',
                        help="Set N_RADIAL",
                        type=int,
                        default=0)
    parser.add_argument('-ny',
                        metavar='N',
                        help="Set N_TOROIDAL",
                        type=int,
                        default=0)
    parser.add_argument('-ntheta',
                        metavar='N',
                        help="Set N_THETA",
                        type=int,
                        default=0)
    parser.add_argument('-lx',
                        metavar='L',
                        help="Box size in x (sets BOX_SIZE via shear)",
                        type=float,
                        default=0.0)
    parser.add_argument('-ly',
                        metavar='L',
                        help="Box size in y (sets KY = 2*pi/ly)",
                        type=float,
                        default=0.0)

    # Velocity resolution
    parser.add_argument('-ne',
                        metavar='N',
                        help="Set N_ENERGY",
                        type=int,
                        default=0)
    parser.add_argument('-nxi',
                        metavar='N',
                        help="Set N_XI",
                        type=int,
                        default=0)
    parser.add_argument('-emax',
                        metavar='E',
                        help="Set E_MAX",
                        type=float,
                        default=0.0)

    # Time domain
    parser.add_argument('-dt',
                        metavar='T',
                        help="Set DELTA_T",
                        type=float,
                        default=0.0)
    parser.add_argument('-dtm',
                        metavar='N',
                        help="Set DELTA_T_METHOD",
                        type=int,
                        default=-1)

    parser.add_argument('-pure',
                        help="Set N_SPECIES=2 for pure plasma",
                        action='store_true')

    parser.add_argument('-r',
                        metavar='I,J',
                        help="Remove ion species I, transfer density to species J\n"
                             "(e.g., -r 4,1 removes species 4, adds its density to species 1)",
                        type=str,
                        default='')

    parser.add_argument('-quiet',
                        help="Suppress diagnostic output",
                        action='store_true')

    args=parser.parse_args()

    return args

args = opts()

if args.template == 'null':
    mydir = args.e+'/'
    msg(f'Processing simulation in {mydir}')
else:
    mydir = args.e+'/work/'
    msg(f'Processing template {args.template}')
    os.system('mkdir -p work')
    os.system('cp '+args.template+' work/input.cgyro')
    msg('Running cgyro -t to parse template (see work/cgyro_t.log)')
    os.system('cd work ; cgyro -t > cgyro_t.log 2>&1')

# Sanity checks
if not os.path.isdir(mydir):
    error_exit('directory does not exist')

if not os.path.isfile(mydir+'input.cgyro.gen'):
    error_exit('input.cgyro.gen missing')

# Read data
msg('Reading simulation data')
sim = data.cgyrodata(mydir,silent=True)

# Check for legacy global data
if min(sim.z) > 0.0:
    msg('(WARNING) Detected old PROFILE_MODEL')
    sim.getequil_legacy()

try:
    with open(mydir+'out.cgyro.version', 'r') as file:
        for line in file:
            pass
        version = line.strip()
except:
    version = 'unavailable'

if sim.n_species == 1:
    error_exit('Conversion not implemented for adiabatic electrons.')

# Electron index
for i in range(sim.n_species):
    if sim.z[i] < 0.0:
        ielec = i

msg(f'Found {sim.n_species} species (electron index: {ielec+1})')

#==================================================================
# json.cgyro.localdump

d = {}

msg('Loading parameter defaults from input.json')
with open(garoot+'/cgyro/bin/util/input.json','r') as file:
    default = json.load(file)

# Read all values from input.cgyro.gen (converted to proper numeric types)
with open(mydir+'input.cgyro.gen','r') as file:
    for line in file:
        u = line.split()
        key = u[1]
        value = u[0]
        if key in default.keys() and 'SHAPE' not in key:
            # Convert to appropriate numeric type
            try:
                if '.' in value or 'e' in value.lower():
                    d[key] = float(value)
                else:
                    d[key] = int(value)
            except ValueError:
                d[key] = value

# Fill in any missing parameters from defaults (excluding arrays and SHAPE)
for key in default:
    if key not in d and not isinstance(default[key], list) and 'SHAPE' not in key:
        d[key] = default[key]

# Code-specific parameters
d['N_ENERGY'] = sim.n_energy
d['N_XI'] = sim.n_xi
d['N_THETA'] = sim.n_theta
d['N_RADIAL'] = sim.n_radial
d['N_TOROIDAL'] = sim.n_n
d['N_FIELD'] = sim.n_field

# Physics parameters
d['RMIN'] = sim.rmin
d['RMAJ'] = sim.rmaj
d['Q'] = sim.q
d['S'] = sim.shear
d['MACH'] = sim.mach
d['GAMMA_E'] = sim.gamma_e
d['GAMMA_P'] = sim.gamma_p
d['BETAE_UNIT'] = sim.betae_unit
d['NU_EE'] = sim.nu[ielec]
d['LAMBDA_STAR'] = sim.lambda_star

d['ZMAG'] = sim.zmag
d['DZMAG'] = sim.dzmag
d['SHIFT'] = sim.shift
d['KAPPA'] = sim.kappa
d['S_KAPPA'] = sim.s_kappa
d['DELTA'] = sim.delta
d['S_DELTA'] = sim.s_delta
d['ZETA'] = sim.zeta
d['S_ZETA'] = sim.s_zeta

d['SHAPE_SIN'] = sim.shape_sin[:].tolist()
d['SHAPE_COS'] = sim.shape_cos[:].tolist()
d['SHAPE_S_SIN'] = sim.shape_s_sin[:].tolist()
d['SHAPE_S_COS'] = sim.shape_s_cos[:].tolist()

d['Z'] = sim.z[:].tolist()
d['MASS'] = sim.mass[:].tolist()
d['DENS'] = sim.dens[:].tolist()
d['TEMP'] = sim.temp[:].tolist()
d['DLNNDR'] = sim.dlnndr[:].tolist()
d['DLNTDR'] = sim.dlntdr[:].tolist()

# Species removal: -r I,J removes species I, transfers density to species J
if args.r:
    try:
        remove_spec, target_spec = map(int, args.r.split(','))
        # Convert to 0-based indices
        i_remove = remove_spec - 1
        i_target = target_spec - 1

        n_species = sim.n_species
        if i_remove < 0 or i_remove >= n_species:
            error_exit(f'species {remove_spec} out of range')
        if i_target < 0 or i_target >= n_species:
            error_exit(f'target species {target_spec} out of range')
        if i_remove == i_target:
            error_exit('cannot remove species to itself')

        # Transfer density to target species
        d['DENS'][i_target] += d['DENS'][i_remove]

        # Remove species from all arrays and shift down
        for key in ['Z', 'MASS', 'DENS', 'TEMP', 'DLNNDR', 'DLNTDR']:
            del d[key][i_remove]

        # Update N_SPECIES
        d['N_SPECIES'] = n_species - 1

        msg(f'Removed species {remove_spec}, density transferred to species {target_spec}')

    except ValueError:
        error_exit('-r requires format I,J (e.g., -r 4,1)')

# Quasineutrality check: sum(n_i * z_i) should be ~0
qn_sum = sum(n*z for n, z in zip(d['DENS'], d['Z']))
msg(f'Quasineutrality check: sum(n_i*z_i) = {qn_sum:.6e}')
if abs(qn_sum) > 1e-6:
    msg('(WARNING) Quasineutrality violated')

# Resolution parameter handling
# Command-line overrides take priority; otherwise use existing or default
# Tuple: (cmdline_value, sentinel) - sentinel is value meaning "not set"
resolution_params = {
    'N_RADIAL': (args.nx, 0),
    'N_TOROIDAL': (args.ny, 0),
    'N_THETA': (args.ntheta, 0),
    'N_ENERGY': (args.ne, 0),
    'N_XI': (args.nxi, 0),
    'E_MAX': (args.emax, 0.0),
    'DELTA_T': (args.dt, 0.0),
    'DELTA_T_METHOD': (args.dtm, -1),
}

# Track which resolution params are set (for template mode output)
resolution_keys = list(resolution_params.keys()) + ['KY', 'BOX_SIZE']

msg('Setting resolution parameters')
for key, (cmdval, sentinel) in resolution_params.items():
    if cmdval != sentinel:
        # Command-line override
        d[key] = cmdval
        msg(f'{key}={cmdval} (command-line)', indent=True)
    elif key not in d:
        # Absent in template, use default
        d[key] = default[key]
        msg(f'{key}={default[key]} (default)', indent=True)
    # else: keep existing value in d

# Derived spatial parameters (KY, BOX_SIZE) from -lx, -ly
if args.lx > 0.0 or args.ly > 0.0:
    lx = args.lx if args.lx > 0.0 else 90.0
    ly = args.ly if args.ly > 0.0 else 90.0
    d['KY'] = digit(2*np.pi/ly, 4)
    d['BOX_SIZE'] = digit(lx*d['S']*d['KY'], 0)
    msg(f'KY={d["KY"]} BOX_SIZE={d["BOX_SIZE"]} (from lx={lx}, ly={ly})', indent=True)
elif 'KY' not in d:
    d['KY'] = default['KY']
    d['BOX_SIZE'] = default['BOX_SIZE']
    msg(f'KY={d["KY"]} BOX_SIZE={d["BOX_SIZE"]} (default)', indent=True)

if args.pure:
    d['N_SPECIES'] = 2
    d['DENS'] = sim.dens[:].tolist()
    msg('Pure plasma mode: N_SPECIES=2')

#==================================================================
# JSON output
with open(mydir+'json.cgyro.localdump','w') as f:
    json.dump(d, f, indent=2, sort_keys=True)
msg('Wrote json.cgyro.localdump')

#==================================================================
# Construct TGLF input file

tglf = {}

tglf['RMIN_LOC']=sim.rmin
tglf['RMAJ_LOC'] = sim.rmaj
tglf['Q_LOC'] = abs(sim.q)
tglf['Q_PRIME_LOC'] = sim.shear*(tglf['Q_LOC']/tglf['RMIN_LOC'])**2
tglf['P_PRIME_LOC'] = ( -sim.beta_star/8/np.pi)*abs(tglf['Q_LOC']/tglf['RMIN_LOC'])

tglf['NS'] = sim.n_species
for i in range(1, tglf['NS']+1):
    tglf[f'VPAR_{i}'] = abs(sim.mach)
    tglf[f'VPAR_SHEAR_{i}'] = abs(sim.gamma_p)

tglf['VEXB_SHEAR'] = sim.gamma_e
tglf['BETAE'] = sim.betae_unit
tglf['XNUE'] = sim.nu[ielec]
tglf['ZEFF'] = sim.z_eff
tglf['DEBYE'] = sim.lambda_star

tglf['ZMAJ_LOC']=sim.zmag
tglf['DZMAJDX_LOC']=sim.dzmag
tglf['DRMAJDX_LOC']=sim.shift

tglf['KAPPA_LOC'] = sim.kappa
tglf['S_KAPPA_LOC'] = sim.s_kappa
tglf['DELTA_LOC'] = sim.delta
tglf['S_DELTA_LOC'] = sim.s_delta
tglf['ZETA_LOC'] = sim.zeta
tglf['S_ZETA_LOC'] = sim.s_zeta

x = d['SHAPE_SIN']
for i in range(3,len(x)):
    if x[i] != 0.0: 
        tglf[f'SHAPE_SIN{i}']=x[i]
x = d['SHAPE_COS']
for i in range(0,len(x)):
    if x[i] != 0:
        tglf[f'SHAPE_COS{i}']=x[i]
x = d['SHAPE_S_SIN']
for i in range(3,len(x)):
    if x[i] != 0:
        tglf[f'SHAPE_S_SIN{i}']=x[i]
x = d['SHAPE_S_COS']
for i in range(0,len(x)):
    if x[i] != 0:
        tglf[f'SHAPE_S_COS{i}']=x[i]

# Species arrays (TGLF has electron first, CGYRO has electron last)
tglf_species_array(tglf, 'ZS', d['Z'])
tglf_species_array(tglf, 'MASS', d['MASS'])
tglf_species_array(tglf, 'AS', d['DENS'])
tglf_species_array(tglf, 'TAUS', d['TEMP'])
tglf_species_array(tglf, 'RLNS', d['DLNNDR'])
tglf_species_array(tglf, 'RLTS', d['DLNTDR'])

with open(mydir+'out.cgyro.tglf','w') as f:
    for item in tglf:
        f.write(item+'='+str(tglf[item])+'\n')

msg('Wrote out.cgyro.tglf')

#==================================================================
# localdump output (sparse: non-default values only)
#
# Filter d to only include non-default values
# In template mode, always include resolution parameters
d_full = dict(d)  # Keep full copy if needed later
d = {}
for key in d_full:
    # In template mode, always include resolution parameters
    if args.template != 'null' and key in resolution_keys:
        d[key] = d_full[key]
    elif key in default:
        if isinstance(d_full[key], list):
            # For arrays, include if any element differs
            if d_full[key] != default[key]:
                d[key] = d_full[key]
        elif d_full[key] != default[key]:
            d[key] = d_full[key]
    else:
        # Key not in defaults (e.g., SHAPE arrays), always include
        d[key] = d_full[key]

nmax = 0
with open(mydir+'out.cgyro.localdump','w') as f:

    write_section(f, 'Numerical resolution',
        ['N_ENERGY', 'E_MAX', 'N_XI', 'N_TOROIDAL', 'N_RADIAL', 'N_THETA', 'THETA_PLOT'], d, first=True)
    write_section(f, 'Simulation box', ['KY', 'BOX_SIZE'], d)
    write_section(f, 'Time domain', ['DELTA_T_METHOD', 'DELTA_T', 'PRINT_STEP', 'MAX_TIME'], d)
    write_section(f, 'Basic geometry',
        ['RMIN', 'RMAJ', 'Q', 'S', 'SHIFT', 'KAPPA', 'S_KAPPA', 'DELTA', 'S_DELTA'], d)
    write_section(f, 'Physics',
        ['NONLINEAR_FLAG', 'N_FIELD', 'BETAE_UNIT', 'BETA_STAR_SCALE', 'LAMBDA_STAR', 'NU_EE', 'COLLISION_MODEL'], d)
    write_section(f, 'Rotation', ['ROTATION_MODEL', 'MACH', 'GAMMA_E', 'GAMMA_P'], d)
    write_section(f, 'Advanced shape', ['ZETA', 'S_ZETA', 'ZMAG', 'DZMAG'], d)

    # Shape coefficients (write non-zero elements with index suffix)
    f.write('\n# Shape coefficients\n')
    for key in list(d.keys()):
        if 'SHAPE' in key:
            x = d.pop(key)
            for i, val in enumerate(x):
                if val != 0.0:
                    f.write(f'{key}{i}={val}\n')
                    nmax = max(nmax, i)

    # Species parameters (write with _N suffix)
    f.write('\n# Species parameters\n')
    if 'N_SPECIES' in d:
        f.write(f'N_SPECIES={d.pop("N_SPECIES")}\n')
    for key in list(d.keys()):
        if isinstance(d[key], list):
            arr = d.pop(key)
            for i, val in enumerate(arr):
                f.write(f'{key}_{i+1}={val}\n')

    # Remaining parameters
    write_section(f, 'Miscellaneous', list(d.keys()), d)


msg('Wrote out.cgyro.localdump')
#==================================================================

if args.template != 'null':
    os.system('cp work/out.cgyro.localdump input.cgyro')
    os.system('rm -r work')
    msg('Template processing complete')
    msg('Created input.cgyro with physics + resolution parameters')
    sys.exit()

#==================================================================
# json.cgyro.imas

nmax = nmax+1

if nmax < 3:
    nmax = 3

# Reference dimensions in CGYRO units
lref=sim.rmaj
vthref = np.sqrt(2.0)
bref = sim.b_gs2

# Initialize dictionary
d = {}

#--------------------------------------------------------------------
# Species and profiles

d['name'] = 'CGYRO'
d['version'] = version
d['r_minor_norm'] = sim.rmin/lref
d['magnetic_shear_r_minor'] = sim.shear
d['q'] = sim.q
d['charge_norm'] = sim.z[:].tolist()
d['mass_norm'] = sim.mass[:].tolist()
d['density_norm'] = sim.dens[:].tolist()
d['temperature_norm'] = sim.temp[:].tolist()
d['density_log_gradient_norm'] = (lref*sim.dlnndr[:]).tolist()
d['temperature_log_gradient_norm'] = (lref*sim.dlntdr[:]).tolist()
#--------------------------------------------------------------------

#--------------------------------------------------------------------
# Rotation, collisons, beta
d['velocity_tor_norm'] = sim.mach/vthref
# -L/v 1/B (r/q Bu) (-dw/dr) = L/v Bu/B (r/q dw/dr) = L/v Bu/B (-GAMMA_E)
d['shearing_rate_norm'] = -(lref/vthref)/bref*sim.gamma_e
# -L^2/v dw/dr = -L/v (L dw/dr) = -L/v (-GAMMA_P)
d['velocity_tor_gradient_norm'] = lref/vthref*sim.gamma_p
# nu_ee
d['collisionality_norm'] = (lref/vthref)*sim.nu[ielec]
# electron beta
d['beta_reference'] = sim.betae_unit/bref**2
# pressure gradient
d['pressure_gradient_norm'] = -lref*sim.beta_star/bref**2
# Debye length (normalized to lref)
d['debye_length_reference'] = sim.lambda_star*sim.rho/lref
#-----------------------------------------------------------------------

#-----------------------------------------------------------------------
# Geometry

d['dgeometric_axis_r_dr_minor'] = sim.shift
d['dgeometric_axis_z_dr_minor'] = sim.dzmag

d['elongation'] = sim.kappa
d['delongation_dr_minor_norm'] = sim.s_kappa*sim.kappa*lref/sim.rmin

# Shape coefficients (cn,sn)
d['shapecoefficients_c'] = sim.shape_cos[:nmax].tolist()
d['shapecoefficients_s'] = sim.shape_sin[:nmax].tolist()
d['shapecoefficients_s'][1] = np.arcsin(sim.delta)
d['shapecoefficients_s'][2] = -sim.zeta

# Derivatives of (cn,sn)
d['dc_dr_minor_norm'] = (sim.shape_s_cos[:nmax]*lref/sim.rmin).tolist()
d['ds_dr_minor_norm'] = (sim.shape_s_sin[:nmax]*lref/sim.rmin).tolist()
d['ds_dr_minor_norm'][1] = sim.s_delta*lref/sim.rmin/np.cos(np.arcsin(sim.delta))
d['ds_dr_minor_norm'][2] = -sim.s_zeta*lref/sim.rmin
#-----------------------------------------------------------------------

with open(mydir+'json.cgyro.imas','w') as f:
    json.dump(d, f, indent=2, sort_keys=True)
msg('Wrote json.cgyro.imas')
#==================================================================

