#!/usr/bin/env python

import os
import sys
import json
import numpy as np
import argparse
import textwrap
from pygacode.cgyro import data
from cgyro_util import PARAM_GROUPS, Logger, load_defaults, write_section, parse_cgyro_gen

#==================================================================
def opts():
    mytext = '''\
Output files (written to simulation directory):
  json.cgyro.localdump  Complete parameter dump in JSON format
  json.cgyro.imas       IMAS-compatible data dictionary in JSON format
  out.cgyro.localdump   Sparse localdump (non-default values only)
  out.cgyro.tglf        Equivalent TGLF input file

Examples:
  cgyro --json                   Export all formats from current directory
  cgyro --json -e /path/to/sim   Export from specified simulation directory
  cgyro --json -tglf             Export TGLF format only
  cgyro --json -imas             Export IMAS format only

Note: For creating/modifying input.cgyro files, use cgyro --pre instead.
    '''

    p = argparse.ArgumentParser(
        formatter_class=argparse.RawTextHelpFormatter,
        prog='cgyro_json',
        description="Export CGYRO simulation data to JSON and other formats.\n"
                    "Requires input.cgyro.gen (run 'cgyro -t' first if needed).",
        epilog=textwrap.dedent(mytext))

    p.add_argument('-e', metavar='DIR', type=str, default='.',
                   help="Simulation directory (default: current directory)")
    p.add_argument('-tglf', action='store_true', help="Export TGLF format only")
    p.add_argument('-imas', action='store_true', help="Export IMAS format only")
    p.add_argument('-localdump', action='store_true', help="Export localdump formats only")
    p.add_argument('-quiet', action='store_true', help="Suppress diagnostic output")

    return p.parse_args()

args = opts()
log = Logger('cgyro_json', args.quiet)

#==================================================================
# Determine exports

export_all = not (args.tglf or args.imas or args.localdump)
do_tglf = export_all or args.tglf
do_imas = export_all or args.imas
do_dump = export_all or args.localdump

#==================================================================
# Load simulation

mydir = args.e + '/'
log(f'Processing simulation in {mydir}')

if not os.path.isdir(mydir):
    log.error('directory does not exist')
if not os.path.isfile(mydir + 'input.cgyro.gen'):
    log.error("input.cgyro.gen missing (run 'cgyro -t' first)")

log('Reading simulation data')
sim = data.cgyrodata(mydir, silent=True)

if min(sim.z) > 0.0:
    log('(WARNING) Detected old PROFILE_MODEL')
    sim.getequil_legacy()

try:
    with open(mydir + 'out.cgyro.version', 'r') as f:
        version = f.readlines()[-1].strip()
except:
    version = 'unavailable'

if sim.n_species == 1:
    log.error('Conversion not implemented for adiabatic electrons.')

ielec = next(i for i in range(sim.n_species) if sim.z[i] < 0.0)
log(f'Found {sim.n_species} species (electron index: {ielec+1})')

#==================================================================
# Build parameter dict

default = load_defaults()
d = parse_cgyro_gen(mydir + 'input.cgyro.gen', default)

# Fill defaults
for k, v in default.items():
    if k not in d and not isinstance(v, list) and 'SHAPE' not in k:
        d[k] = v

# Override with simulation values
d.update({
    'N_ENERGY': sim.n_energy, 'N_XI': sim.n_xi, 'N_THETA': sim.n_theta,
    'N_RADIAL': sim.n_radial, 'N_TOROIDAL': sim.n_n, 'N_FIELD': sim.n_field,
    'RMIN': sim.rmin, 'RMAJ': sim.rmaj, 'Q': sim.q, 'S': sim.shear,
    'MACH': sim.mach, 'GAMMA_E': sim.gamma_e, 'GAMMA_P': sim.gamma_p,
    'BETAE_UNIT': sim.betae_unit, 'NU_EE': sim.nu[ielec], 'LAMBDA_STAR': sim.lambda_star,
    'ZMAG': sim.zmag, 'DZMAG': sim.dzmag, 'SHIFT': sim.shift,
    'KAPPA': sim.kappa, 'S_KAPPA': sim.s_kappa,
    'DELTA': sim.delta, 'S_DELTA': sim.s_delta,
    'ZETA': sim.zeta, 'S_ZETA': sim.s_zeta,
    'SHAPE_SIN': sim.shape_sin[:].tolist(), 'SHAPE_COS': sim.shape_cos[:].tolist(),
    'SHAPE_S_SIN': sim.shape_s_sin[:].tolist(), 'SHAPE_S_COS': sim.shape_s_cos[:].tolist(),
    'Z': sim.z[:].tolist(), 'MASS': sim.mass[:].tolist(), 'DENS': sim.dens[:].tolist(),
    'TEMP': sim.temp[:].tolist(), 'DLNNDR': sim.dlnndr[:].tolist(), 'DLNTDR': sim.dlntdr[:].tolist(),
})

#==================================================================
# Export: json.cgyro.localdump

if do_dump:
    with open(mydir + 'json.cgyro.localdump', 'w') as f:
        json.dump(d, f, indent=2, sort_keys=True)
    log('Wrote json.cgyro.localdump')

#==================================================================
# Export: out.cgyro.tglf

def tglf_species(tglf, prefix, arr):
    """TGLF species: electron first (last in CGYRO), ions following."""
    tglf[f'{prefix}_1'] = arr[-1]
    for i in range(2, len(arr) + 1):
        tglf[f'{prefix}_{i}'] = arr[i-2]

if do_tglf:
    t = {
        'RMIN_LOC': sim.rmin, 'RMAJ_LOC': sim.rmaj, 'Q_LOC': abs(sim.q),
        'Q_PRIME_LOC': sim.shear * (abs(sim.q) / sim.rmin)**2,
        'P_PRIME_LOC': (-sim.beta_star / 8 / np.pi) * abs(sim.q / sim.rmin),
        'NS': sim.n_species, 'VEXB_SHEAR': sim.gamma_e,
        'BETAE': sim.betae_unit, 'XNUE': sim.nu[ielec], 'ZEFF': sim.z_eff,
        'DEBYE': sim.lambda_star, 'ZMAJ_LOC': sim.zmag, 'DZMAJDX_LOC': sim.dzmag,
        'DRMAJDX_LOC': sim.shift, 'KAPPA_LOC': sim.kappa, 'S_KAPPA_LOC': sim.s_kappa,
        'DELTA_LOC': sim.delta, 'S_DELTA_LOC': sim.s_delta,
        'ZETA_LOC': sim.zeta, 'S_ZETA_LOC': sim.s_zeta,
    }
    for i in range(1, t['NS'] + 1):
        t[f'VPAR_{i}'] = abs(sim.mach)
        t[f'VPAR_SHEAR_{i}'] = abs(sim.gamma_p)

    # Shape coefficients (non-zero only)
    for name, start in [('SHAPE_SIN', 3), ('SHAPE_COS', 0), ('SHAPE_S_SIN', 3), ('SHAPE_S_COS', 0)]:
        for i, v in enumerate(d[name][start:], start):
            if v != 0.0:
                t[f'{name}{i}'] = v

    for prefix, arr in [('ZS', d['Z']), ('MASS', d['MASS']), ('AS', d['DENS']),
                        ('TAUS', d['TEMP']), ('RLNS', d['DLNNDR']), ('RLTS', d['DLNTDR'])]:
        tglf_species(t, prefix, arr)

    with open(mydir + 'out.cgyro.tglf', 'w') as f:
        for k, v in t.items():
            f.write(f'{k}={v}\n')
    log('Wrote out.cgyro.tglf')

#==================================================================
# Export: out.cgyro.localdump (sparse)

if do_dump:
    sparse = {k: v for k, v in d.items()
              if k not in default or (isinstance(v, list) and v != default[k]) or
              (not isinstance(v, list) and v != default.get(k))}

    nmax = 0
    with open(mydir + 'out.cgyro.localdump', 'w') as f:
        write_section(f, 'Numerical resolution',
                      ['N_ENERGY', 'E_MAX', 'N_XI', 'N_TOROIDAL', 'N_RADIAL', 'N_THETA', 'THETA_PLOT'],
                      sparse, first=True)
        write_section(f, 'Simulation box', ['KY', 'BOX_SIZE'], sparse)
        write_section(f, 'Time domain', PARAM_GROUPS['time'], sparse)
        write_section(f, 'Geometry', PARAM_GROUPS['geometry'], sparse)
        write_section(f, 'Physics', PARAM_GROUPS['physics'], sparse)
        write_section(f, 'Rotation', PARAM_GROUPS['rotation'], sparse)

        f.write('\n# Shape coefficients\n')
        for key in [k for k in sparse if 'SHAPE' in k]:
            for i, v in enumerate(sparse.pop(key)):
                if v != 0.0:
                    f.write(f'{key}{i}={v}\n')
                    nmax = max(nmax, i)

        f.write('\n# Species parameters\n')
        if 'N_SPECIES' in sparse:
            f.write(f'N_SPECIES={sparse.pop("N_SPECIES")}\n')
        for key in [k for k in list(sparse) if isinstance(sparse[k], list)]:
            for i, v in enumerate(sparse.pop(key)):
                f.write(f'{key}_{i+1}={v}\n')

        write_section(f, 'Miscellaneous', list(sparse.keys()), sparse)
    log('Wrote out.cgyro.localdump')

#==================================================================
# Export: json.cgyro.imas

if do_imas:
    nmax = max(nmax + 1 if 'nmax' in dir() else 3, 3)
    lref, vthref, bref = sim.rmaj, np.sqrt(2.0), sim.b_gs2

    imas = {
        'name': 'CGYRO', 'version': version,
        'r_minor_norm': sim.rmin / lref, 'magnetic_shear_r_minor': sim.shear, 'q': sim.q,
        'charge_norm': sim.z[:].tolist(), 'mass_norm': sim.mass[:].tolist(),
        'density_norm': sim.dens[:].tolist(), 'temperature_norm': sim.temp[:].tolist(),
        'density_log_gradient_norm': (lref * sim.dlnndr[:]).tolist(),
        'temperature_log_gradient_norm': (lref * sim.dlntdr[:]).tolist(),
        'velocity_tor_norm': sim.mach / vthref,
        'shearing_rate_norm': -(lref / vthref) / bref * sim.gamma_e,
        'velocity_tor_gradient_norm': lref / vthref * sim.gamma_p,
        'collisionality_norm': (lref / vthref) * sim.nu[ielec],
        'beta_reference': sim.betae_unit / bref**2,
        'pressure_gradient_norm': -lref * sim.beta_star / bref**2,
        'debye_length_reference': sim.lambda_star * sim.rho / lref,
        'dgeometric_axis_r_dr_minor': sim.shift,
        'dgeometric_axis_z_dr_minor': sim.dzmag,
        'elongation': sim.kappa,
        'delongation_dr_minor_norm': sim.s_kappa * sim.kappa * lref / sim.rmin,
        'shapecoefficients_c': sim.shape_cos[:nmax].tolist(),
        'shapecoefficients_s': sim.shape_sin[:nmax].tolist(),
        'dc_dr_minor_norm': (sim.shape_s_cos[:nmax] * lref / sim.rmin).tolist(),
        'ds_dr_minor_norm': (sim.shape_s_sin[:nmax] * lref / sim.rmin).tolist(),
    }
    imas['shapecoefficients_s'][1] = np.arcsin(sim.delta)
    imas['shapecoefficients_s'][2] = -sim.zeta
    imas['ds_dr_minor_norm'][1] = sim.s_delta * lref / sim.rmin / np.cos(np.arcsin(sim.delta))
    imas['ds_dr_minor_norm'][2] = -sim.s_zeta * lref / sim.rmin

    with open(mydir + 'json.cgyro.imas', 'w') as f:
        json.dump(imas, f, indent=2, sort_keys=True)
    log('Wrote json.cgyro.imas')

log('Export complete')
