#!/usr/bin/env python

import os
import sys
import json
import re
import subprocess
import argparse

def opts():
    p = argparse.ArgumentParser(
        prog='cgyro_loc',
        description='Python wrapper for locpargen (local parameter extraction from input.gacode)')

    p.add_argument('-rad', type=float, default=0.0,
                   help='Reference radius r/a')
    p.add_argument('-rho', type=float, default=0.0,
                   help='Reference rho = sqrt[chi/chi(a)]')
    p.add_argument('-psi', type=float, default=0.0,
                   help='Reference psi_N = psi/psi(a)')
    p.add_argument('-qn', action='store_true',
                   help='Enforce quasineutrality')
    p.add_argument('-nion', type=int, default=0,
                   help='Number of ions to retain (0=keep all)')
    p.add_argument('-ntheta', type=int, default=0,
                   help='Number of theta points for geometry output')
    p.add_argument('-append', action='store_true',
                   help='Append to existing input.*.locpargen files')
    p.add_argument('-banana', action='store_true',
                   help='Include banana-width diagnostic')

    return p.parse_args()

def parse_locpargen_stdout(output):
    """Parse key physics quantities from locpargen stdout."""
    # (name, regex, units or None)
    fields = [
        ('rmin_over_a', r'rmin/a\s*=\s*(\S+)',              None),
        ('rho',         r'rho\s*=\s*(\S+)',                  None),
        ('psi_N',       r'psi_N\s*=\s*(\S+)',                None),
        ('rhos_over_a', r'rhos/a\s*=\s*(\S+)',               None),
        ('Te',          r'Te \[keV\]\s*=\s*(\S+)',           'keV'),
        ('Ti',          r'Ti \[keV\]\s*=\s*(\S+)',           'keV'),
        ('ne',          r'ne \[e19/m\^3\]\s*=\s*(\S+)',      'e19/m^3'),
        ('cs',          r'cs \[m/s\]\s*=\s*(\S+)',           'm/s'),
        ('Q_GB',        r'Q_GB \[MW/m\^2\]\s*=\s*(\S+)',    'MW/m^2'),
        ('GAMMA_GB',    r'GAMMA_GB \[e19/m\^2/s\]\s*=\s*(\S+)', 'e19/m^2/s'),
        ('PI_GB',       r'PI_GB \[N/m\]\s*=\s*(\S+)',       'N/m'),
    ]

    values = {}
    units = {}
    for name, pat, unit in fields:
        m = re.search(pat, output)
        if m:
            values[name] = float(m.group(1))
            if unit:
                units[name] = unit

    return values, units

def parse_cgyro_locpargen(filename):
    """Parse NU_EE, BETAE_UNIT, LAMBDA_STAR from input.cgyro.locpargen."""
    result = {}
    keys = {'NU_EE': 'nu_ee', 'BETAE_UNIT': 'betae_unit', 'LAMBDA_STAR': 'lambda_star'}

    if not os.path.isfile(filename):
        return result

    with open(filename) as f:
        for line in f:
            line = line.strip()
            if '=' not in line or line.startswith('#'):
                continue
            name, _, val = line.partition('=')
            name = name.strip()
            if name in keys:
                result[keys[name]] = float(val)

    return result

def main():
    args = opts()

    # Require at least one radial specification
    if args.rad == 0.0 and args.rho == 0.0 and args.psi == 0.0:
        print('ERROR: (cgyro_loc) Must specify one of -rad, -rho, or -psi')
        sys.exit(1)

    # Check for input.gacode
    if not os.path.isfile('input.gacode'):
        print('ERROR: (cgyro_loc) input.gacode not found in current directory')
        sys.exit(1)

    # Check for locpargen executable
    gacode_root = os.environ.get('GACODE_ROOT', '')
    locpargen_exe = os.path.join(gacode_root, 'profiles_gen', 'locpargen', 'locpargen')
    if not os.path.isfile(locpargen_exe):
        print('ERROR: (cgyro_loc) locpargen executable not found. Build it first.')
        sys.exit(1)

    # Write input.locpargen
    qnflag = 1 if args.qn else 0
    appendflag = 1 if args.append else 0

    with open('input.locpargen', 'w') as f:
        f.write(f'{args.rad}\n')
        f.write(f'{args.rho}\n')
        f.write(f'{args.psi}\n')
        f.write(f'{qnflag}\n')
        f.write(f'{appendflag}\n')
        f.write(f'{args.ntheta}\n')
        f.write(f'{args.nion}\n')

    # Run locpargen
    result = subprocess.run([locpargen_exe], capture_output=True, text=True)

    # Print stdout/stderr passthrough
    if result.stdout:
        print(result.stdout, end='')
    if result.stderr:
        print(result.stderr, end='', file=sys.stderr)

    # Clean up input file
    if os.path.isfile('input.locpargen'):
        os.remove('input.locpargen')

    if result.returncode != 0:
        print('ERROR: (cgyro_loc) locpargen failed')
        sys.exit(1)

    # Optional banana width
    if args.banana:
        prgen_bin = os.path.join(gacode_root, 'profiles_gen', 'bin')
        subprocess.run([sys.executable, os.path.join(prgen_bin, 'banana_width.py')])

    # Optional geometry plot
    if args.ntheta > 0:
        plot_script = os.path.join(gacode_root, 'f2py', 'pygacode',
                                   'profiles_gen', 'plot_locpargen_geo.py')
        subprocess.run([sys.executable, plot_script, str(args.ntheta)])

    # Build JSON from stdout diagnostics and input.cgyro.locpargen
    json_data, units = parse_locpargen_stdout(result.stdout)
    json_data.update(parse_cgyro_locpargen('input.cgyro.locpargen'))
    json_data['units'] = units

    if json_data:
        json_file = 'out.locpargen.json'
        with open(json_file, 'w') as f:
            json.dump(json_data, f, indent=2)
        print(f'INFO: (cgyro_loc) Wrote {json_file}')

if __name__ == '__main__':
    main()
