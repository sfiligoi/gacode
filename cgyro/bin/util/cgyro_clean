#!/usr/bin/env python

import os,sys,glob
import shutil
import tarfile
import argparse
import textwrap

mytext = '''\
output:
   This command provides tools for cleaning and copying cgyro directories.
   Examples:

   cgyro --c clean              (cleans current directory recursively)
   cgyro --c clean -opt         (cleans but preserves timing files)
   cgyro --c copy -i idir       (creates idir_copy without restart files)
   cgyro --c copy -i idir -tgz  (creates idir_copy.tgz without restart files)
'''

parser = argparse.ArgumentParser(
    formatter_class=argparse.RawTextHelpFormatter,
    prog = 'cgyro --c',
    description="Directory clean/copy utility",
    epilog=textwrap.dedent(mytext))

subparsers = parser.add_subparsers(dest='mode')

# clean subcommand
p_clean = subparsers.add_parser('clean',help='Clean directories recursively')
p_clean.add_argument('-opt',
                     help='Preserve timing files',
                     action='store_true')

# copy subcommand
p_copy = subparsers.add_parser('copy',help='Copy directory without restart files')
p_copy.add_argument('-i',
                    help='Source directory',
                    type=str,
                    required=True)
p_copy.add_argument('-nokxky',
                    help='Suppress copying bin.cgyro.kxky* files',
                    action='store_true')
p_copy.add_argument('-minimal',
                    help='Remove non-essential output files and kxky files from copy',
                    action='store_true')
p_copy.add_argument('-tgz',
                    help='Compress copied directory into a tgz file',
                    action='store_true')
p_copy.add_argument('-v',
                    help='Verbose output',
                    action='store_true')

args = parser.parse_args()

if args.mode is None:
    parser.print_help()
    sys.exit()

#------------------------------------------------------------------------
# clean mode
#
if args.mode == 'clean':

    if args.opt:
        # Keep timing
        patterns = ['**/out.cgyro.[a-s]*',
                    '**/out.cgyro.t[a-h]*',
                    '**/out.cgyro.time',
                    '**/out.cgyro.[u-z]*',
                    '**/bin.*',
                    '**/*gen',
                    '**/batch.err',
                    '**/batch.out']
    else:
        patterns = ['**/out.cgyro.*',
                    '**/bin.*',
                    '**/*gen',
                    '**/batch.err',
                    '**/batch.out']

    for pattern in patterns:
        for file in glob.glob(pattern,recursive=True):
            os.remove(file)

#------------------------------------------------------------------------
# copy mode
#
elif args.mode == 'copy':

    idir = args.i
    tdir = idir+'_copy'

    flags = '-av' if args.v else '-a'

    # Files to always exclude from copy
    exfiles = ['bin.cgyro.restart',
               'bin.cgyro.restart.old',
               'bin.cgyro.restart.part',
               'halt',
               'gyrotest_flag',
               'out.log']

    if args.nokxky or args.minimal:
        exfiles.append('bin.cgyro.kxky*')

    if args.minimal:
        exfiles += ['out.cgyro.hosts',
                    'out.cgyro.memory',
                    'out.cgyro.mpi',
                    'out.cgyro.rotation',
                    'out.cgyro.startups',
                    'out.cgyro.tag',
                    'out.cgyro.timing']

    exstr = ""
    for ex in exfiles:
        exstr = exstr+"--exclude '"+ex+"' "

    os.system("rsync "+flags+" "+exstr+idir+"/ "+tdir)

    # Compress into tgz and remove directory
    if args.tgz:
        with tarfile.open(tdir+'.tgz','w:gz') as tar:
            tar.add(tdir,arcname=os.path.basename(tdir))
        shutil.rmtree(tdir)
