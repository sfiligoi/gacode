#!/usr/bin/env python

import os,sys,glob
import numpy as np
import argparse
import textwrap

# Command line option parser
def opts():

    mytext = '''\
    output:
       This command provides tools for cleaning and copying xgyro directories.
       Examples:

       cgyro --c -c              (cleans current directory recursively)
       cgyro --c -i idir         (creates copy of idir without restart files)
       cgyro --c -i idir -t tdir (copies idir -> tdir without restart files)
    '''

    parser = argparse.ArgumentParser(
        formatter_class=argparse.RawTextHelpFormatter,
        prog = 'cgyro_clean',
        description="Directory clean/copy utility",
        epilog=textwrap.dedent(mytext))

    parser.add_argument('-i',
                        help='initial directory (default: cwd)',
                        type=str,
                        nargs='?')
    parser.add_argument('-t',
                        help='target directory (default: _copy)',
                        type=str,
                        nargs='?')
    parser.add_argument('-c',
                        help='Clean directories recursively (all out.* and bin.* files)',
                        action='store_true')
    parser.add_argument('-opt',
                        help='Preserve timing files',
                        action='store_true')
    parser.add_argument('-nokxky',
                        help='Suppress copying bin.cgyro.kxky* files',
                        action='store_true')
    parser.add_argument('-v',
                        help='Verbose output',
                        action='store_true')

    args=parser.parse_args()

    return args.i,args.t,args.c,args.opt,args.nokxky,args.v

#------------------------------------------------------------------------
#
idir,tdir,c,opt,nokxky,v = opts()

# Check for no arguments
if idir is None and tdir is None and not c:
    sys.exit()

    
if opt:
    # Keep timing 
    patterns = ['**/out.cgyro.[a-s]*',
                '**/out.cgyro.time',
                '**/bin.*',
                '**/*gen',
                '**/batch.err',
                '**/batch.out']
else:
    patterns = ['**/out.cgyro.*',
                '**/bin.*',
                '**/*gen',
                '**/batch.err',
                '**/batch.out']
 
# Recursive clean
if c:
    for pattern in patterns:
        for file in glob.glob(pattern,recursive=True):
            os.remove(file)
    
    sys.exit()

if idir is None:
    print('ERROR: specify -i <idir>')
    sys.exit()

if tdir is None:
    tdir = idir+'_copy/'

idir = idir+'/'

if v:
    flags = '-av'
else:
    flags = '-a'

# Directory copy
exfiles = ['bin.cgyro.restart',
           'bin.cgyro.restart.old',
           'bin.cgyro.restart.part',
           'halt',
           'gyrotest_flag',
           'out.log']

if nokxky:
    exfiles.append('bin.cgyro.kxky*')

exstr = ""
for ex in exfiles:
    exstr = exstr+"--exclude '"+ex+"' "

os.system("rsync "+flags+" "+exstr+idir+" "+tdir)


