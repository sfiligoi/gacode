#!/usr/bin/env python3
"""Generate perturbation combinations as a simple text file."""

import argparse
from itertools import product


def parse_spec(spec_str):
    """Parse 'VAR:val1,val2,val3' into (var_name, [values])."""
    if ':' not in spec_str:
        raise ValueError(f"Invalid spec: {spec_str}")

    var_name, values_str = spec_str.split(':', 1)
    values = []
    for v in values_str.split(','):
        v = v.strip()
        if '.' in v or 'e' in v.lower():
            values.append(float(v))
        else:
            values.append(int(v))

    return var_name.strip(), values


def main():
    parser = argparse.ArgumentParser(description='Generate perturbation combinations')
    parser.add_argument('-p', action='append', required=True,
                        help='Specs: "VAR:val1,val2;VAR2:val1,val2" (can be used multiple times)')
    parser.add_argument('-o', '--output', default='pre.xgyro',
                        help='Output file (default: pre.xgyro)')
    args = parser.parse_args()

    all_combinations = []

    # Process each -p group independently
    for p_group in args.p:
        specs = []
        for spec_str in p_group.split(';'):
            spec_str = spec_str.strip()
            if spec_str:
                specs.append(parse_spec(spec_str))

        var_names = [s[0] for s in specs]
        value_arrays = [s[1] for s in specs]
        combinations = list(product(*value_arrays))

        # Convert combinations to strings
        for combo in combinations:
            parts = [f"{var}={val}" for var, val in zip(var_names, combo)]
            all_combinations.append(' '.join(parts))

    # Write all combinations to file
    with open(args.output, 'w') as f:
        for line in all_combinations:
            f.write(line + '\n')

    print(f"Created {len(all_combinations)} perturbations in {args.output}")
    return 0


if __name__ == '__main__':
    exit(main())
