#!/usr/bin/env python
"""
cgyro_dbplot - CGYRO Interactive Database Plotter

Wrapper script to launch Streamlit app for interactive database exploration.
"""

import os
import sys
import argparse
import subprocess


def main():
    parser = argparse.ArgumentParser(description='CGYRO Interactive Database Plotter')
    parser.add_argument('-db', '--database',
                      help='Database path (default: ~/.cgyro/cgyro_ai.db)')
    args = parser.parse_args()

    # Get path to the streamlit app
    script_dir = os.path.dirname(os.path.abspath(__file__))
    app_path = os.path.join(script_dir, 'cgyro_dbplot_app.py')

    if not os.path.exists(app_path):
        print(f"ERROR: Streamlit app not found at {app_path}")
        sys.exit(1)

    # Build streamlit command
    cmd = ['streamlit', 'run', app_path]

    # Pass database path if provided
    if args.database:
        cmd.extend(['--', '-db', args.database])

    print(f"Launching CGYRO Database Explorer...")
    print(f"Database: {args.database if args.database else '~/.cgyro/cgyro_ai.db'}")
    print(f"\nStreamlit will open in your browser automatically.")
    print(f"Press Ctrl+C to stop the server.\n")

    # Launch streamlit
    subprocess.run(cmd)


if __name__ == '__main__':
    main()
