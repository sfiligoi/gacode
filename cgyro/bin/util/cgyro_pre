#!/usr/bin/env python

import os,sys,re,glob
import numpy as np
import argparse
import textwrap

# Command line option parser
def opts():

    mytext = '''\
    output:
       This command generates cgyro input directories based on a template.
       Examples:

       cgyro --pre -i <template>     (run)
    '''

    parser = argparse.ArgumentParser(
        formatter_class=argparse.RawTextHelpFormatter,
        prog = 'cgyro_pre',
        description="Directory generator",
        epilog=textwrap.dedent(mytext))

    parser.add_argument('-i',
                        help='input.cgyro template',
                        type=str,
                        default='null')
    parser.add_argument('-p',
                        help='pre.xgyro overlays',
                        type=str,
                        default='null')
    parser.add_argument('-f',
                        help='Force overwrite',
                        action='store_true')
    parser.add_argument('-v',
                        help='Verbose output',
                        action='store_true')
    parser.add_argument('-add',
                        help='Add to existing datasets',
                        action='store_true')
    parser.add_argument('-b',
                        help='base directory name',
                        type=str,
                        default='null')
    
    args=parser.parse_args()

    return args.i,args.p,args.f,args.v,args.add,args.b

#------------------------------------------------------------------------
#
infile,prefile,force,verbose,add,base = opts()

with open(prefile,'r') as f:
    # Reject lines that start with '#' or are blank
    lines = [line for line in f if line.strip() and not line.strip().startswith('#')]

cpu = []
apar = []
if base == 'null':
    base = 'a'

# Old directory check
if glob.glob(base+'*/'):
    if force:
        os.system('rm -r {}*'.format(base))
    elif not add:
        print('ERROR: clean directories first')
        sys.exit()

# Create new directories
i = 1
for line in lines:
    row = line.strip().split()
    if row[0] == 'ALL':
        apar = row[1:]
        continue
    sdir = base+str(i)
    i = i+1
    os.system('mkdir '+sdir)
    os.system('cp {} {}/input.cgyro'.format(infile,sdir))
    for par in row[:]:
        # Add parameter to local input.cgyro
        action = 'echo {} >> {}/input.cgyro'.format(par,sdir)
        os.system(action)
        if len(apar) > 0:
            for par in apar:
                action = 'echo {} >> {}/input.cgyro'.format(par,sdir)
                os.system(action)


n = i

if add:
    # Read existing input.xgyro
    with open('input.xgyro','r') as f:
        content = f.read()

    # Find current value, increment it, and replace
    match = re.search(r'N_DIRS\s*=\s*(\d+)',content)
    if match:
        old_value = int(match.group(1))
        new_value = old_value + n
        content = re.sub(r'N_DIRS\s*=\s*\d+', f'N_DIRS={new_value}',content)
    
        # Write back
        with open('input.xgyro','w') as f:
            f.write(content)
else:

    old_value = 0
    
    # header for input.xgyro 
    mystr = '# This file created by cgyro --pre \nN_DIRS={}'.format(n)
    action = 'echo "{}" > input.xgyro'.format(mystr)
    os.system(action)

for i in range(n):
    action = 'echo "DIR_{} = {}{}" >> input.xgyro'.format(i+1+old_value,base,i+1)
    os.system(action)
