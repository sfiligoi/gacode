#!/usr/bin/env python

import os
import sys
import json
import glob
import argparse
import textwrap
from cgyro_util import (ARG_MAP, RESOLUTION_PARAMS, Logger, load_defaults,
                        compute_ky_boxsize, read_input_cgyro, parse_input_xgyro,
                        write_input_xgyro, apply_params, get_param, parse_cgyro_gen)

#==================================================================
def opts():
    mytext = '''\
Modes of operation:

  TEMPLATE MODE: Generate input.cgyro from physics template
    cgyro --pre -template FILE                    Single template
    cgyro --pre -template FILE -resfile res.json  With resolution from JSON
    cgyro --pre -template FILE -nx 128 -ne 12     With resolution overrides
    cgyro --pre -template DIR -resfile res.json   Bulk mode: process all input.cgyro*
                                                  files in DIR, output to a1/, a2/, ...

  SYNC MODE: Update existing input.cgyro files with parameters from resfile
    cgyro --pre -sync -resfile res.json           Update dirs listed in input.xgyro

  OVERLAY MODE: Create directories with parameter overlays (original --pre behavior)
    cgyro --pre -overlay pre.xgyro                Apply overlays to input.cgyro template
    cgyro --pre -overlay pre.xgyro -i template    Use custom template

Resfile format (JSON):
  Any valid CGYRO parameter. Special keys 'lx' and 'ly' are converted to KY/BOX_SIZE.
  {
    "N_RADIAL": 128, "N_ENERGY": 12, "DELTA_T": 0.01, "lx": 90.0, "ly": 90.0
  }

Overlay file format (pre.xgyro):
  One set of parameters per line, space-separated. Lines starting with # are ignored.
  ALL keyword applies parameters to all cases.
  Example:
    ALL MAX_TIME=100
    N_RADIAL=64 N_ENERGY=8
    N_RADIAL=128 N_ENERGY=12
    '''

    p = argparse.ArgumentParser(
        formatter_class=argparse.RawTextHelpFormatter,
        prog='cgyro_pre',
        description="CGYRO input manager: create and modify input.cgyro files.",
        epilog=textwrap.dedent(mytext))

    # Mode selection
    p.add_argument('-template', metavar='FILE|DIR', type=str, default='null',
                   help="Template mode: process input.cgyro physics template.\n"
                        "If DIR, scan for input.cgyro* files (bulk mode).")
    p.add_argument('-sync', action='store_true',
                   help="Sync mode: apply resfile to all dirs in input.xgyro.")
    p.add_argument('-overlay', metavar='FILE', type=str, default='null',
                   help="Overlay mode: create dirs with parameter overlays.")

    # Common options
    p.add_argument('-resfile', metavar='FILE', type=str, default='null',
                   help="JSON file with parameters to apply.")
    p.add_argument('-i', metavar='FILE', type=str, default='input.cgyro',
                   help="Input template for overlay mode (default: input.cgyro).")
    p.add_argument('-b', metavar='NAME', type=str, default='a',
                   help="Base directory name (default: a).")
    p.add_argument('-f', action='store_true', help="Force overwrite existing directories.")

    # Resolution parameters
    p.add_argument('-nx', metavar='N', type=int, default=0, help="N_RADIAL (radial modes)")
    p.add_argument('-ny', metavar='N', type=int, default=0, help="N_TOROIDAL (toroidal modes)")
    p.add_argument('-ntheta', metavar='N', type=int, default=0, help="N_THETA (poloidal grid)")
    p.add_argument('-ne', metavar='N', type=int, default=0, help="N_ENERGY (energy grid)")
    p.add_argument('-nxi', metavar='N', type=int, default=0, help="N_XI (pitch angle grid)")
    p.add_argument('-emax', metavar='E', type=float, default=0.0, help="E_MAX (max energy)")
    p.add_argument('-dt', metavar='T', type=float, default=0.0, help="DELTA_T (time step)")
    p.add_argument('-dtm', metavar='N', type=int, default=-1, help="DELTA_T_METHOD")
    p.add_argument('-lx', metavar='L', type=float, default=0.0, help="Box size x -> BOX_SIZE")
    p.add_argument('-ly', metavar='L', type=float, default=0.0, help="Box size y -> KY")

    # Species and output
    p.add_argument('-pure', action='store_true', help="Set N_SPECIES=2 for pure plasma.")
    p.add_argument('-r', metavar='I,J', type=str, default='',
                   help="Remove species I, transfer density to species J.")
    p.add_argument('-quiet', action='store_true', help="Suppress diagnostic output.")

    return p.parse_args()

args = opts()
log = Logger('cgyro_pre', args.quiet)

#==================================================================
# Load resfile

resdata = {}
if args.resfile != 'null':
    if not os.path.isfile(args.resfile):
        log.error(f'resfile not found: {args.resfile}')
    log(f'Loading parameters from {args.resfile}')
    with open(args.resfile, 'r') as f:
        resdata = json.load(f)
    # Apply ARG_MAP parameters to args if not overridden
    for key, (attr, sentinel) in ARG_MAP.items():
        if key in resdata and getattr(args, attr) == sentinel:
            setattr(args, attr, resdata[key])

#==================================================================
# Validate mode

modes = [args.template != 'null', args.sync, args.overlay != 'null']
if sum(modes) != 1:
    log.error('must specify exactly one of: -template, -sync, -overlay')

#==================================================================
# SYNC MODE

if args.sync:
    if args.resfile == 'null':
        log.error('-sync requires -resfile')
    sync_dirs = parse_input_xgyro()
    if not sync_dirs:
        log.error('no directories found in input.xgyro')

    log(f'Sync mode: updating {len(sync_dirs)} directories')
    lx_val, ly_val = resdata.pop('lx', None), resdata.pop('ly', None)

    for d in sync_dirs:
        path = os.path.join(d, 'input.cgyro')
        if not os.path.isfile(path):
            log(f'(WARNING) {path} not found, skipping')
            continue
        lines, params = read_input_cgyro(path)
        updated = apply_params(lines, params, resdata)

        if lx_val is not None or ly_val is not None:
            shear = get_param(lines, 'S')
            if shear is None:
                log(f'(WARNING) S not found in {path}')
            else:
                ky, bs = compute_ky_boxsize(lx_val or 90.0, ly_val or 90.0, shear)
                params = {l.strip().split('=')[0]: i for i, l in enumerate(lines)
                          if '=' in l and not l.strip().startswith('#')}
                apply_params(lines, params, {'KY': ky, 'BOX_SIZE': bs})
                updated += ['KY', 'BOX_SIZE']

        with open(path, 'w') as f:
            f.writelines(lines)
        log(f'{d}: {", ".join(updated)}', indent=True)
    log('Sync complete')
    sys.exit()

#==================================================================
# OVERLAY MODE

if args.overlay != 'null':
    if not os.path.isfile(args.overlay):
        log.error(f'overlay file not found: {args.overlay}')
    if not os.path.isfile(args.i):
        log.error(f'template not found: {args.i}')

    with open(args.overlay, 'r') as f:
        lines = [l for l in f if l.strip() and not l.strip().startswith('#')]

    base, all_params = args.b, []
    if glob.glob(f'{base}*/'):
        if args.f:
            os.system(f'rm -rf {base}*')
        else:
            log.error(f'directories {base}* exist (use -f to overwrite)')

    with open(args.i, 'r') as f:
        template = f.read()

    dirs = []
    for line in lines:
        row = line.strip().split()
        if row[0] == 'ALL':
            all_params = row[1:]
            continue
        dirs.append(f'{base}{len(dirs)+1}')
        os.makedirs(dirs[-1], exist_ok=True)
        with open(f'{dirs[-1]}/input.cgyro', 'w') as f:
            f.write(template)
            for p in row + all_params:
                f.write(f'{p}\n')
        log(f'Created {dirs[-1]}/', indent=True)

    write_input_xgyro(dirs, 'cgyro --pre')
    log(f'Created {len(dirs)} directories')
    sys.exit()

#==================================================================
# TEMPLATE MODE

def process_template(template_path, default, resdata, args, log):
    """Process a single template, return dict of parameters."""
    os.system('mkdir -p work')
    os.system(f'cp "{template_path}" work/input.cgyro')
    os.system('cd work ; cgyro -t > cgyro_t.log 2>&1')

    if not os.path.isfile('work/input.cgyro.gen'):
        log.error('cgyro -t failed (see work/cgyro_t.log)')

    d = parse_cgyro_gen('work/input.cgyro.gen', default)
    os.system('rm -rf work')

    # Apply resolution: command-line > resfile > existing > default
    for key in RESOLUTION_PARAMS:
        attr, sentinel = ARG_MAP[key]
        cmdval = getattr(args, attr)
        if cmdval != sentinel:
            d[key] = cmdval
        elif key in resdata:
            d[key] = resdata[key]
        elif key not in d:
            d[key] = default[key]

    # Non-resolution resfile params
    for key, val in resdata.items():
        if key not in ARG_MAP and key not in ('lx', 'ly'):
            d[key] = val

    # lx/ly -> KY/BOX_SIZE
    if args.lx > 0.0 or args.ly > 0.0:
        d['KY'], d['BOX_SIZE'] = compute_ky_boxsize(
            args.lx or 90.0, args.ly or 90.0, d.get('S', 1.0))
    elif 'KY' not in d:
        d['KY'], d['BOX_SIZE'] = default['KY'], default['BOX_SIZE']

    if args.pure:
        d['N_SPECIES'] = 2

    # Species removal: -r I,J removes species I, transfers density to species J
    if args.r:
        try:
            remove_spec, target_spec = map(int, args.r.split(','))
            i_remove = remove_spec - 1  # Convert to 0-based
            i_target = target_spec - 1

            n_species = d.get('N_SPECIES', len(d.get('Z', [])))
            if i_remove < 0 or i_remove >= n_species:
                log.error(f'species {remove_spec} out of range')
            if i_target < 0 or i_target >= n_species:
                log.error(f'target species {target_spec} out of range')
            if i_remove == i_target:
                log.error('cannot remove species to itself')

            # Transfer density
            if 'DENS' in d:
                d['DENS'][i_target] += d['DENS'][i_remove]

            # Remove from all species arrays
            for key in ['Z', 'MASS', 'DENS', 'TEMP', 'DLNNDR', 'DLNTDR']:
                if key in d and isinstance(d[key], list) and len(d[key]) > i_remove:
                    del d[key][i_remove]

            d['N_SPECIES'] = n_species - 1
            log(f'Removed species {remove_spec}, density transferred to species {target_spec}')

        except ValueError:
            log.error('-r requires format I,J (e.g., -r 4,1)')

    # Quasineutrality check
    if 'DENS' in d and 'Z' in d:
        qn_sum = sum(n * z for n, z in zip(d['DENS'], d['Z']))
        log(f'Quasineutrality: sum(n_i*z_i) = {qn_sum:.3e}')

    return d

def write_input_cgyro(d, default, filepath='input.cgyro'):
    """Write input.cgyro from parameter dict."""
    # Keys to skip in physics section (handled separately)
    skip = {'N_ENERGY', 'E_MAX', 'N_XI', 'N_TOROIDAL', 'N_RADIAL', 'N_THETA',
            'KY', 'BOX_SIZE', 'DELTA_T', 'DELTA_T_METHOD', 'MAX_TIME', 'PRINT_STEP'}
    # Species arrays need indexed output
    species_keys = {'Z', 'MASS', 'DENS', 'TEMP', 'DLNNDR', 'DLNTDR'}

    with open(filepath, 'w') as f:
        f.write('# Numerical resolution\n')
        for k in ['N_ENERGY', 'E_MAX', 'N_XI', 'N_TOROIDAL', 'N_RADIAL', 'N_THETA']:
            if k in d:
                f.write(f'{k}={d[k]}\n')
        f.write('\n# Simulation box\n')
        for k in ['KY', 'BOX_SIZE']:
            if k in d:
                f.write(f'{k}={d[k]}\n')
        f.write('\n# Time domain\n')
        for k in ['DELTA_T', 'DELTA_T_METHOD', 'MAX_TIME', 'PRINT_STEP']:
            if k in d and (k not in default or d[k] != default[k]):
                f.write(f'{k}={d[k]}\n')

        f.write('\n# Physics\n')
        for k in sorted(d.keys()):
            if k in skip or k in species_keys or 'SHAPE' in k:
                continue
            val = d[k]
            if isinstance(val, list):
                continue  # Skip any remaining lists
            if (k in default and val != default[k]) or k not in default:
                f.write(f'{k}={val}\n')

        f.write('\n# Species\n')
        n_species = d.get('N_SPECIES', 1)
        f.write(f'N_SPECIES={n_species}\n')
        for k in species_keys:
            if k in d and isinstance(d[k], list):
                for i in range(min(n_species, len(d[k]))):
                    f.write(f'{k}_{i+1}={d[k][i]}\n')

        # SHAPE arrays (non-zero only)
        has_shape = False
        for k in sorted(d.keys()):
            if 'SHAPE' in k and isinstance(d[k], list):
                for i, val in enumerate(d[k]):
                    if val != 0.0:
                        if not has_shape:
                            f.write('\n# Shape coefficients\n')
                            has_shape = True
                        f.write(f'{k}{i}={val}\n')

if args.template != 'null':
    default = load_defaults()

    if os.path.isdir(args.template):
        # Bulk mode
        templates = sorted(glob.glob(os.path.join(args.template, 'input.cgyro*')))
        if not templates:
            log.error(f'no input.cgyro files found in {args.template}')

        log(f'Bulk mode: found {len(templates)} templates')
        base = args.b
        if glob.glob(f'{base}*/'):
            if args.f:
                os.system(f'rm -rf {base}*')
            else:
                log.error(f'directories {base}* exist (use -f to overwrite)')

        log('To stop, create HALT file')
        dirs = []
        for i, t in enumerate(templates):
            if os.path.exists('HALT'):
                log('HALT detected')
                os.remove('HALT')
                break
            outdir = f'{base}{i+1}'
            log(f'[{i+1}/{len(templates)}] {t} -> {outdir}/')
            d = process_template(t, default, resdata, args, log)
            os.makedirs(outdir, exist_ok=True)
            write_input_cgyro(d, default, f'{outdir}/input.cgyro')
            dirs.append(outdir)

        write_input_xgyro(dirs, 'cgyro --pre')
        log(f'Created {len(dirs)} directories')
    else:
        # Single template
        if not os.path.isfile(args.template):
            log.error(f'template not found: {args.template}')
        log(f'Processing template {args.template}')
        d = process_template(args.template, default, resdata, args, log)
        write_input_cgyro(d, default)
        log('Created input.cgyro')
